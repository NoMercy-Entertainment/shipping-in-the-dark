---
/**
 * ReportAudioPlayer — multi-track player for long-form reports.
 *
 * Differences from AudioPlayer.astro:
 *   - Holds a list of tracks (one per report part).
 *   - Auto-advances to the next track on 'ended'.
 *   - Skip-to-next-section button.
 *   - Male/female narrator toggle.
 *   - Emits 'audio-part-change' so AudioSync knows which part is active and
 *     which VTT to load.
 *
 * Voice choice persists in localStorage under 'sitd:narrator-voice'.
 */
type VoiceVariantMap = {
	brief: string;
	elaborate: string;
};

interface Track {
	slug: string;
	title: string;
	part: number;
	audio: { female: VoiceVariantMap; male: VoiceVariantMap };
	vtt: { female: VoiceVariantMap; male: VoiceVariantMap };
}

interface Props {
	tracks: Track[];
	title?: string;
}

const { tracks, title = '' } = Astro.props;
const tracksJson = JSON.stringify(tracks);
---

<div
	id="report-audio-player"
	class="audio-player report-audio-player"
	data-tracks={tracksJson}
	data-title={title}
	aria-label="Report audio player"
	role="region"
>
	<div
		id="audio-progress-bar"
		class="audio-progress-bar"
		role="progressbar"
		aria-valuemin="0"
		aria-valuemax="100"
		aria-valuenow="0"
		aria-label="Playback progress"
		tabindex="0"
	>
		<div id="audio-progress-fill" class="audio-progress-fill"></div>
	</div>

	<div class="audio-controls">
		<button id="audio-prev-btn" class="audio-secondary-btn" aria-label="Previous part" type="button" title="Previous part">
			<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" width="18" height="18">
				<path d="M7 6h2v12H7zm3.5 6l8.5 6V6z" />
			</svg>
		</button>

		<button id="audio-section-prev-btn" class="audio-secondary-btn" aria-label="Previous section" type="button" title="Previous section">
			<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" width="16" height="16">
				<polyline points="11 17 6 12 11 7" />
				<polyline points="18 17 13 12 18 7" />
			</svg>
		</button>

		<button id="audio-play-btn" class="audio-play-btn" aria-label="Play" type="button">
			<svg id="icon-play" class="audio-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
				<path d="M8 5v14l11-7z" />
			</svg>
			<svg id="icon-pause" class="audio-icon hidden" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
				<path d="M6 19h4V5H6zm8-14v14h4V5z" />
			</svg>
		</button>

		<button id="audio-section-next-btn" class="audio-secondary-btn" aria-label="Next section" type="button" title="Next section">
			<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" width="16" height="16">
				<polyline points="6 7 11 12 6 17" />
				<polyline points="13 7 18 12 13 17" />
			</svg>
		</button>

		<button id="audio-skip-btn" class="audio-secondary-btn" aria-label="Next part" type="button" title="Next part">
			<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" width="18" height="18">
				<path d="M6 6l8.5 6L6 18V6zm11 0h2v12h-2V6z" />
			</svg>
		</button>

		<div class="audio-time" aria-live="off">
			<span id="audio-current" class="audio-current">0:00</span>
			<span class="audio-separator" aria-hidden="true">/</span>
			<span id="audio-duration" class="audio-duration">0:00</span>
		</div>

		<div id="audio-title" class="audio-title" aria-label="Now playing">
			<span id="audio-part-num" class="audio-part-num"></span>
			<span id="audio-part-title"></span>
		</div>

		<div class="audio-voice-menu-wrap">
			<button
				id="audio-voice-btn"
				class="audio-voice-btn"
				aria-haspopup="true"
				aria-expanded="false"
				aria-controls="audio-voice-menu"
				aria-label="Narrator voice"
				type="button"
				title="Pick narrator voice"
			>
				<span id="audio-voice-label">Aria</span>
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" width="10" height="10">
					<polyline points="6 9 12 15 18 9"></polyline>
				</svg>
			</button>
			<ul id="audio-voice-menu" class="audio-voice-menu" role="menu" hidden>
				<li role="none">
					<button type="button" role="menuitemradio" data-voice-key="female">
						<span class="voice-name">Aria</span>
						<span class="voice-desc">Female narrator</span>
					</button>
				</li>
				<li role="none">
					<button type="button" role="menuitemradio" data-voice-key="male">
						<span class="voice-name">Guy</span>
						<span class="voice-desc">Male narrator</span>
					</button>
				</li>
			</ul>
		</div>

		<div class="audio-voice-menu-wrap">
			<button
				id="audio-variant-btn"
				class="audio-voice-btn"
				aria-haspopup="true"
				aria-expanded="false"
				aria-controls="audio-variant-menu"
				aria-label="Narration depth"
				type="button"
				title="Brief or elaborate code descriptions"
			>
				<span id="audio-variant-label">Brief</span>
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" width="10" height="10">
					<polyline points="6 9 12 15 18 9"></polyline>
				</svg>
			</button>
			<ul id="audio-variant-menu" class="audio-voice-menu" role="menu" hidden>
				<li role="none">
					<button type="button" role="menuitemradio" data-variant-key="brief">
						<span class="voice-name">Brief</span>
						<span class="voice-desc">Short code descriptions</span>
					</button>
				</li>
				<li role="none">
					<button type="button" role="menuitemradio" data-variant-key="elaborate">
						<span class="voice-name">Elaborate</span>
						<span class="voice-desc">Walk through each field</span>
					</button>
				</li>
			</ul>
		</div>

		<div class="audio-speed-group" role="group" aria-label="Playback speed">
			<button id="audio-speed-down" class="audio-speed-step" aria-label="Slower" type="button" title="Slower">
				<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" width="12" height="12">
					<path d="M19 13H5v-2h14v2z"/>
				</svg>
			</button>
			<span id="audio-speed-display" class="audio-speed-display" aria-live="polite">1x</span>
			<button id="audio-speed-up" class="audio-speed-step" aria-label="Faster" type="button" title="Faster">
				<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" width="12" height="12">
					<path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
				</svg>
			</button>
		</div>
	</div>
</div>

<style is:global>
	.report-audio-player {
		transform: translateY(0);
	}

	.audio-secondary-btn {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 32px;
		height: 32px;
		border-radius: 50%;
		border: none;
		cursor: pointer;
		background-color: var(--color-surface-800);
		color: var(--color-surface-100);
		flex-shrink: 0;
		transition: background-color 0.15s ease, transform 0.1s ease;
		outline: none;
	}
	html.light .audio-secondary-btn {
		background-color: var(--color-surface-200);
		color: var(--color-surface-900);
	}
	.audio-secondary-btn:hover {
		background-color: var(--color-surface-700);
	}
	html.light .audio-secondary-btn:hover {
		background-color: var(--color-surface-300);
	}
	.audio-secondary-btn:focus-visible {
		outline: 2px solid var(--color-accent-400);
		outline-offset: 2px;
	}

	/* -------- Voice dropdown -------- */
	.audio-voice-menu-wrap {
		position: relative;
		flex-shrink: 0;
	}

	.audio-voice-btn {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		font-family: var(--font-mono);
		font-size: 0.6875rem;
		font-weight: 600;
		color: var(--color-surface-400);
		background-color: var(--color-surface-800);
		border: 1px solid var(--color-surface-700);
		border-radius: 9999px;
		padding: 3px 10px;
		cursor: pointer;
		transition: color 0.15s ease, background-color 0.15s ease;
		outline: none;
		white-space: nowrap;
	}
	html.light .audio-voice-btn {
		color: var(--color-surface-600);
		background-color: var(--color-surface-200);
		border-color: var(--color-surface-300);
	}
	.audio-voice-btn:hover {
		color: var(--color-surface-100);
		background-color: var(--color-surface-700);
	}
	html.light .audio-voice-btn:hover {
		color: var(--color-surface-900);
		background-color: var(--color-surface-300);
	}
	.audio-voice-btn:focus-visible {
		outline: 2px solid var(--color-accent-400);
		outline-offset: 2px;
	}
	.audio-voice-btn[aria-expanded="true"] svg {
		transform: rotate(180deg);
	}
	.audio-voice-btn svg {
		transition: transform 0.15s ease;
	}

	.audio-voice-menu {
		position: absolute;
		bottom: calc(100% + 8px);
		right: 0;
		min-width: 10.5rem;
		margin: 0;
		padding: 4px;
		list-style: none;
		background-color: var(--color-surface-900);
		border: 1px solid var(--color-surface-700);
		border-radius: 8px;
		box-shadow: 0 4px 18px rgba(0, 0, 0, 0.35);
		z-index: 55;
	}
	html.light .audio-voice-menu {
		background-color: var(--color-surface-50);
		border-color: var(--color-surface-300);
	}
	.audio-voice-menu li { margin: 0; }
	.audio-voice-menu button {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 2px;
		width: 100%;
		padding: 8px 10px;
		background: transparent;
		border: 0;
		border-radius: 5px;
		color: var(--color-surface-200);
		cursor: pointer;
		text-align: left;
		font-family: inherit;
	}
	html.light .audio-voice-menu button { color: var(--color-surface-900); }
	.audio-voice-menu button:hover,
	.audio-voice-menu button:focus-visible {
		background-color: var(--color-surface-800);
		outline: none;
	}
	html.light .audio-voice-menu button:hover,
	html.light .audio-voice-menu button:focus-visible {
		background-color: var(--color-surface-200);
	}
	.audio-voice-menu button[aria-checked="true"] {
		color: var(--color-accent-400);
	}
	html.light .audio-voice-menu button[aria-checked="true"] {
		color: var(--color-accent-700);
	}
	.audio-voice-menu .voice-name {
		font-weight: 600;
		font-size: 0.8125rem;
	}
	.audio-voice-menu .voice-desc {
		font-size: 0.6875rem;
		color: var(--color-surface-500);
	}
	html.light .audio-voice-menu .voice-desc {
		color: var(--color-surface-600);
	}

	/* -------- Speed stepper -------- */
	.audio-speed-group {
		display: inline-flex;
		align-items: stretch;
		flex-shrink: 0;
		border: 1px solid var(--color-surface-700);
		border-radius: 9999px;
		background-color: var(--color-surface-800);
		overflow: hidden;
	}
	html.light .audio-speed-group {
		border-color: var(--color-surface-300);
		background-color: var(--color-surface-200);
	}

	.audio-speed-step {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 24px;
		background: transparent;
		border: 0;
		color: var(--color-surface-400);
		cursor: pointer;
		transition: color 0.15s ease, background-color 0.15s ease;
	}
	html.light .audio-speed-step { color: var(--color-surface-600); }
	.audio-speed-step:hover {
		color: var(--color-surface-100);
		background-color: var(--color-surface-700);
	}
	html.light .audio-speed-step:hover {
		color: var(--color-surface-900);
		background-color: var(--color-surface-300);
	}
	.audio-speed-step:focus-visible {
		outline: 2px solid var(--color-accent-400);
		outline-offset: 2px;
	}
	.audio-speed-step:disabled {
		opacity: 0.35;
		cursor: not-allowed;
	}

	.audio-speed-display {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 2.75rem;
		padding: 0 4px;
		font-family: var(--font-mono);
		font-size: 0.6875rem;
		font-weight: 600;
		color: var(--color-surface-400);
		white-space: nowrap;
	}
	html.light .audio-speed-display { color: var(--color-surface-600); }

	.audio-part-num {
		display: inline-block;
		margin-right: 0.5em;
		font-family: var(--font-mono);
		font-size: 0.7rem;
		color: var(--color-surface-500);
	}
	html.light .audio-part-num {
		color: var(--color-surface-500);
	}

	/* -------- "Play from here" badge on headings -------- */
	.report-part h1,
	.report-part h2,
	.report-part h3,
	.report-part h4 {
		position: relative;
	}

	/*
	  rehype-autolink-headings wraps each heading's inner text in a
	  .heading-anchor and shows a '#' on hover. The play-from-here
	  button lives in the same left margin, so hide the '#' on report
	  headings to avoid the clash. The clickable heading-anchor link
	  (copy-to-clipboard via browser anchor behaviour) still works.
	*/
	.report-part .heading-anchor:hover::before {
		content: none !important;
	}

	.heading-seek-btn {
		position: absolute;
		left: -2.25rem;
		top: 50%;
		transform: translateY(-50%);
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 26px;
		height: 26px;
		border-radius: 50%;
		border: 1px solid var(--color-surface-700);
		background-color: var(--color-surface-900);
		color: var(--color-accent-400);
		cursor: pointer;
		opacity: 0;
		transition: opacity 0.15s ease, background-color 0.15s ease, color 0.15s ease;
		padding: 0;
	}
	html.light .heading-seek-btn {
		border-color: var(--color-surface-300);
		background-color: var(--color-surface-50);
		color: var(--color-accent-700);
	}

	.report-part :is(h1, h2, h3, h4):hover .heading-seek-btn,
	.heading-seek-btn:focus-visible {
		opacity: 1;
	}

	.heading-seek-btn:hover {
		background-color: var(--color-accent-400);
		color: var(--color-surface-950);
	}
	html.light .heading-seek-btn:hover {
		background-color: var(--color-accent-700);
		color: white;
	}

	.heading-seek-btn:focus-visible {
		outline: 2px solid var(--color-accent-400);
		outline-offset: 2px;
	}

	@media (max-width: 768px) {
		.heading-seek-btn {
			position: static;
			transform: none;
			opacity: 1;
			margin-right: 0.5rem;
			vertical-align: middle;
		}
	}
</style>

<script is:inline define:vars={{ tracksJson }}>
(function () {
	'use strict';

	const STORAGE_KEY = 'sitd:narrator-voice';
	const VARIANT_KEY = 'sitd:narration-variant';
	const SPEED_KEY = 'sitd:playback-speed';
	// Per-report position memory. The key is scoped by the tracks array's
	// first slug so two different reports don't stomp each other.
	const POSITION_KEY = 'sitd:report-position';

	const playerEl = document.getElementById('report-audio-player');
	if (!playerEl) return;

	let tracks = [];
	try {
		tracks = JSON.parse(tracksJson);
	} catch (e) {
		console.warn('[ReportAudioPlayer] Failed to parse tracks:', e);
		return;
	}
	if (!tracks.length) return;

	// Global persistent <audio> lives in BaseLayout and survives view
	// transitions. Keeps playback continuous across pages.
	let audio = document.getElementById('sitd-global-audio');
	if (!audio) {
		audio = new Audio();
		audio.preload = 'metadata';
	}

	const speeds = [0.5, 0.75, 1, 1.25, 1.5, 1.75, 2];
	let speedIndex = 2; // start at 1x
	let currentIndex = 0;
	let currentVoice = 'female';
	let currentVariant = 'brief';
	// When the page loads with a heading hash, we fetch that heading's
	// cue start time asynchronously. On the user's first play, apply it
	// before playing so the audio starts at the heading they linked to.
	let pendingInitialSeek = null;
	try {
		const saved = localStorage.getItem(STORAGE_KEY);
		if (saved === 'male' || saved === 'female') currentVoice = saved;
		const savedVariant = localStorage.getItem(VARIANT_KEY);
		if (savedVariant === 'brief' || savedVariant === 'elaborate') currentVariant = savedVariant;
		const savedSpeed = localStorage.getItem(SPEED_KEY);
		if (savedSpeed != null) {
			const idx = speeds.indexOf(parseFloat(savedSpeed));
			if (idx >= 0) speedIndex = idx;
		}
	} catch (e) { /* localStorage blocked */ }

	// Resolve the audio/vtt URL for a track, falling back to the other
	// variant if the requested one is not available (e.g. scripts without
	// variant blocks emit the same audio for both — the CI still writes
	// both files, but be defensive).
	function resolveTrackUrl(trackPart, voice, variant) {
		if (!trackPart) return '';
		if (typeof trackPart === 'string') return trackPart;
		const voiceMap = trackPart[voice];
		if (!voiceMap) return '';
		if (typeof voiceMap === 'string') return voiceMap;
		return voiceMap[variant] || voiceMap.brief || voiceMap.elaborate || '';
	}

	// -------------------------------------------------------------- //
	function showPlayer() {
		playerEl.classList.add('is-visible');
		document.body.classList.add('audio-player-visible');
		document.documentElement.classList.add('audio-player-visible');
	}

	function setPlayingState(playing) {
		const ip = document.getElementById('icon-play');
		const ipa = document.getElementById('icon-pause');
		const pb = document.getElementById('audio-play-btn');
		if (!ip || !ipa || !pb) return;
		if (playing) {
			ip.classList.add('hidden');
			ipa.classList.remove('hidden');
			pb.setAttribute('aria-label', 'Pause');
		} else {
			ip.classList.remove('hidden');
			ipa.classList.add('hidden');
			pb.setAttribute('aria-label', 'Play');
		}
	}

	function formatTime(seconds) {
		if (!isFinite(seconds) || isNaN(seconds)) return '0:00';
		const m = Math.floor(seconds / 60);
		const s = Math.floor(seconds % 60);
		return m + ':' + (s < 10 ? '0' : '') + s;
	}

	function updateProgress() {
		if (!audio.duration) return;
		const pct = (audio.currentTime / audio.duration) * 100;
		const pf = document.getElementById('audio-progress-fill');
		const pb = document.getElementById('audio-progress-bar');
		const ct = document.getElementById('audio-current');
		if (pf) pf.style.width = pct + '%';
		if (pb) pb.setAttribute('aria-valuenow', Math.round(pct));
		if (ct) ct.textContent = formatTime(audio.currentTime);
	}

	function updateVoiceLabel() {
		const label = document.getElementById('audio-voice-label');
		const btn = document.getElementById('audio-voice-btn');
		if (label) label.textContent = currentVoice === 'female' ? 'Aria' : 'Guy';
		if (btn) btn.setAttribute('aria-label', 'Voice: ' + currentVoice + '. Click to switch.');
	}

	function updateTitle(track) {
		const pn = document.getElementById('audio-part-num');
		const pt = document.getElementById('audio-part-title');
		if (pn) pn.textContent = 'Part ' + String(track.part).padStart(2, '0');
		if (pt) pt.textContent = track.title;
	}

	function updateTocHighlight(slug) {
		const links = document.querySelectorAll('.report-toc-link');
		links.forEach((link) => {
			if (link.getAttribute('data-part-slug') === slug) {
				link.classList.add('active');
			} else {
				link.classList.remove('active');
			}
		});
	}

	// -------------------------------------------------------------- //
	function loadTrack(index, opts) {
		opts = opts || {};
		if (index < 0 || index >= tracks.length) return;
		currentIndex = index;
		const track = tracks[index];
		const audioUrl = resolveTrackUrl(track.audio, currentVoice, currentVariant);
		const vttUrl = resolveTrackUrl(track.vtt, currentVoice, currentVariant);

		const resumeTime = opts.resumeAt || 0;
		const autoplay = !!opts.autoplay;

		setPlayingState(false);
		audio.src = audioUrl;
		audio.load();

		// Tell AudioSync which VTT to load and which part to scope to
		const syncData = document.getElementById('audio-sync-data');
		if (syncData) {
			syncData.setAttribute('data-vtt-url', vttUrl);
			syncData.setAttribute('data-part-slug', track.slug);
		}
		document.dispatchEvent(new CustomEvent('audio-part-change', {
			detail: { slug: track.slug, vttUrl: vttUrl, index: index },
		}));

		updateTitle(track);
		updateTocHighlight(track.slug);
		showPlayer();

		// Scroll the part's heading to the top of the viewport — but ONLY
		// when a new track is actively about to play. On initial page load
		// (autoplay:false, resumeAt:0) we leave the viewport where it is
		// so the reader sees the page title + description first.
		// Voice-toggle mid-playback (resumeAt > 0) is a cosmetic swap, not
		// a new section, so we skip the scroll there too.
		if (opts.autoplay && !opts.resumeAt) {
			const section = document.querySelector('section[data-part-slug="' + track.slug + '"]');
			if (section) {
				const heading = section.querySelector('h1, h2') || section;
				heading.scrollIntoView({ behavior: 'smooth', block: 'start' });
			}
		}

		const onReady = () => {
			if (resumeTime) {
				try { audio.currentTime = resumeTime; } catch (e) { /* ignore */ }
			}
			// audio.load() resets playbackRate to 1.0 on Chromium/Safari,
			// so re-apply the stored rate every time a new track loads.
			try { audio.playbackRate = speeds[speedIndex]; } catch (e) { /* ignore */ }
			if (autoplay) {
				audio.play().catch((err) => {
					console.warn('[ReportAudioPlayer] Play blocked:', err);
				});
			}
			audio.removeEventListener('loadedmetadata', onReady);
		};
		audio.addEventListener('loadedmetadata', onReady);
	}

	async function setVoice(newVoice) {
		if (newVoice !== 'female' && newVoice !== 'male') return;
		if (newVoice === currentVoice) {
			closeVoiceMenu();
			return;
		}
		const wasPlaying = !audio.paused;

		// The two voices speak the same script at different paces, so seeking
		// to the same absolute time in the other voice's audio lands on a
		// different paragraph. Re-anchor via the current VTT cue id instead.
		const syncData = document.getElementById('audio-sync-data');
		const activeCue = syncData ? (syncData.getAttribute('data-active-cue') || '') : '';

		currentVoice = newVoice;
		try { localStorage.setItem(STORAGE_KEY, currentVoice); } catch (e) { /* blocked */ }
		updateVoiceLabel();
		updateVoiceMenuChecked();
		closeVoiceMenu();

		let resumeAt = audio.currentTime;
		if (activeCue) {
			const newVttUrl = resolveTrackUrl(tracks[currentIndex].vtt, currentVoice, currentVariant);
			try {
				const start = await fetchVttCueStart(newVttUrl, activeCue);
				if (start != null) resumeAt = start;
			} catch (_) { /* keep the time-based fallback */ }
		}

		loadTrack(currentIndex, { resumeAt: resumeAt, autoplay: wasPlaying });
	}

	async function setVariant(newVariant) {
		if (newVariant !== 'brief' && newVariant !== 'elaborate') return;
		if (newVariant === currentVariant) {
			closeVariantMenu();
			return;
		}
		const wasPlaying = !audio.paused;

		// Variants are the same script with extra sentences in the elaborate
		// version, so the absolute timestamp diverges after any variant
		// block. Re-anchor via the active cue id, same as the voice swap.
		const syncData = document.getElementById('audio-sync-data');
		const activeCue = syncData ? (syncData.getAttribute('data-active-cue') || '') : '';

		currentVariant = newVariant;
		try { localStorage.setItem(VARIANT_KEY, currentVariant); } catch (e) { /* blocked */ }
		updateVariantLabel();
		updateVariantMenuChecked();
		closeVariantMenu();

		let resumeAt = audio.currentTime;
		if (activeCue) {
			const newVttUrl = resolveTrackUrl(tracks[currentIndex].vtt, currentVoice, currentVariant);
			try {
				const start = await fetchVttCueStart(newVttUrl, activeCue);
				if (start != null) resumeAt = start;
			} catch (_) { /* fall back to timestamp */ }
		}

		loadTrack(currentIndex, { resumeAt: resumeAt, autoplay: wasPlaying });
	}

	function updateVariantLabel() {
		const label = document.getElementById('audio-variant-label');
		const btn = document.getElementById('audio-variant-btn');
		const text = currentVariant === 'elaborate' ? 'Elaborate' : 'Brief';
		if (label) label.textContent = text;
		if (btn) btn.setAttribute('aria-label', 'Narration depth: ' + text + '. Click to switch.');
	}

	function updateVariantMenuChecked() {
		const menu = document.getElementById('audio-variant-menu');
		if (!menu) return;
		menu.querySelectorAll('button[data-variant-key]').forEach(function (b) {
			b.setAttribute('aria-checked', b.getAttribute('data-variant-key') === currentVariant ? 'true' : 'false');
		});
	}

	function openVariantMenu() {
		const menu = document.getElementById('audio-variant-menu');
		const btn = document.getElementById('audio-variant-btn');
		if (!menu || !btn) return;
		updateVariantMenuChecked();
		menu.hidden = false;
		btn.setAttribute('aria-expanded', 'true');
	}

	function closeVariantMenu() {
		const menu = document.getElementById('audio-variant-menu');
		const btn = document.getElementById('audio-variant-btn');
		if (menu) menu.hidden = true;
		if (btn) btn.setAttribute('aria-expanded', 'false');
	}

	function toggleVariantMenu() {
		const menu = document.getElementById('audio-variant-menu');
		if (!menu) return;
		if (menu.hidden) openVariantMenu(); else closeVariantMenu();
	}

	function updateVoiceMenuChecked() {
		const menu = document.getElementById('audio-voice-menu');
		if (!menu) return;
		menu.querySelectorAll('button[data-voice-key]').forEach(function (b) {
			b.setAttribute('aria-checked', b.getAttribute('data-voice-key') === currentVoice ? 'true' : 'false');
		});
	}

	function openVoiceMenu() {
		const menu = document.getElementById('audio-voice-menu');
		const btn = document.getElementById('audio-voice-btn');
		if (!menu || !btn) return;
		updateVoiceMenuChecked();
		menu.hidden = false;
		btn.setAttribute('aria-expanded', 'true');
	}

	function closeVoiceMenu() {
		const menu = document.getElementById('audio-voice-menu');
		const btn = document.getElementById('audio-voice-btn');
		if (menu) menu.hidden = true;
		if (btn) btn.setAttribute('aria-expanded', 'false');
	}

	function toggleVoiceMenu() {
		const menu = document.getElementById('audio-voice-menu');
		if (!menu) return;
		if (menu.hidden) openVoiceMenu(); else closeVoiceMenu();
	}

	function skipToNext() {
		const next = currentIndex + 1;
		if (next >= tracks.length) {
			// End of report — stop playback
			audio.pause();
			audio.currentTime = 0;
			return;
		}
		loadTrack(next, { autoplay: true });
	}

	function skipToPrev() {
		// If we're past ~3 seconds, restart the current track; otherwise
		// jump to the previous one. Standard media-player idiom.
		if (audio.currentTime > 3) {
			audio.currentTime = 0;
			return;
		}
		const prev = currentIndex - 1;
		if (prev < 0) {
			audio.currentTime = 0;
			return;
		}
		loadTrack(prev, { autoplay: !audio.paused });
	}

	// Jump to the next heading cue inside the current part. When we're
	// at the final heading of the part, roll into the next part's first
	// heading. Keeps the play/pause state.
	async function skipToNextSection() {
		const vttUrl = resolveTrackUrl(tracks[currentIndex].vtt, currentVoice, currentVariant);
		let headings;
		try { headings = await fetchVttHeadings(vttUrl); } catch (_) { headings = []; }
		const now = audio.currentTime || 0;
		// Anchor a hair past current so we skip the heading we're already on.
		const target = headings.find(function (h) { return h.start > now + 0.1; });
		if (target) {
			try { audio.currentTime = target.start; } catch (_) {}
			return;
		}
		// No next heading in this part — roll to the next part and seek
		// to its first heading if one exists.
		const nextIdx = currentIndex + 1;
		if (nextIdx >= tracks.length) {
			audio.pause();
			return;
		}
		const nextVtt = resolveTrackUrl(tracks[nextIdx].vtt, currentVoice, currentVariant);
		let nextHeadings;
		try { nextHeadings = await fetchVttHeadings(nextVtt); } catch (_) { nextHeadings = []; }
		const wasPlaying = !audio.paused;
		loadTrack(nextIdx, { autoplay: wasPlaying });
		if (nextHeadings.length > 0) {
			const seek = nextHeadings[0].start;
			const onReady = function () {
				audio.removeEventListener('loadedmetadata', onReady);
				try { audio.currentTime = seek; } catch (_) {}
			};
			audio.addEventListener('loadedmetadata', onReady);
		}
	}

	// Previous section: if we're more than ~3 seconds into the current
	// heading, snap to its start. Otherwise jump to the previous heading.
	// Roll back into the previous part if we're on the first heading.
	async function skipToPrevSection() {
		const vttUrl = resolveTrackUrl(tracks[currentIndex].vtt, currentVoice, currentVariant);
		let headings;
		try { headings = await fetchVttHeadings(vttUrl); } catch (_) { headings = []; }
		const now = audio.currentTime || 0;
		let currentHeadingIdx = -1;
		for (let i = 0; i < headings.length; i++) {
			if (headings[i].start <= now) currentHeadingIdx = i;
			else break;
		}
		if (currentHeadingIdx >= 0 && now - headings[currentHeadingIdx].start > 3) {
			try { audio.currentTime = headings[currentHeadingIdx].start; } catch (_) {}
			return;
		}
		const prevInPart = currentHeadingIdx - 1;
		if (prevInPart >= 0) {
			try { audio.currentTime = headings[prevInPart].start; } catch (_) {}
			return;
		}
		// No earlier heading in this part — go to previous part's final heading.
		const prevIdx = currentIndex - 1;
		if (prevIdx < 0) {
			try { audio.currentTime = 0; } catch (_) {}
			return;
		}
		const prevVtt = resolveTrackUrl(tracks[prevIdx].vtt, currentVoice, currentVariant);
		let prevHeadings;
		try { prevHeadings = await fetchVttHeadings(prevVtt); } catch (_) { prevHeadings = []; }
		const wasPlaying = !audio.paused;
		loadTrack(prevIdx, { autoplay: wasPlaying });
		const seek = prevHeadings.length > 0 ? prevHeadings[prevHeadings.length - 1].start : 0;
		const onReady = function () {
			audio.removeEventListener('loadedmetadata', onReady);
			try { audio.currentTime = seek; } catch (_) {}
		};
		audio.addEventListener('loadedmetadata', onReady);
	}

	function setSpeedIndex(i) {
		speedIndex = Math.max(0, Math.min(speeds.length - 1, i));
		const rate = speeds[speedIndex];
		audio.playbackRate = rate;
		try { localStorage.setItem(SPEED_KEY, String(rate)); } catch (e) { /* blocked */ }
		const display = document.getElementById('audio-speed-display');
		const label = (Number.isInteger(rate) ? rate.toFixed(0) : rate.toFixed(2).replace(/\.?0+$/, '')) + 'x';
		if (display) display.textContent = label;
		const down = document.getElementById('audio-speed-down');
		const up = document.getElementById('audio-speed-up');
		if (down) down.toggleAttribute('disabled', speedIndex === 0);
		if (up) up.toggleAttribute('disabled', speedIndex === speeds.length - 1);
	}

	// -------------------------------------------------------------- //
	audio.addEventListener('loadedmetadata', function () {
		const de = document.getElementById('audio-duration');
		if (de) de.textContent = formatTime(audio.duration);
	});

	// Position persistence. Save the reader's spot every few seconds so
	// a refresh or revisit resumes at the same paragraph in the same
	// track with the same voice.
	let lastPositionSaveAt = 0;
	function getReportKey() {
		return POSITION_KEY + ':' + (tracks[0] && tracks[0].slug ? tracks[0].slug : 'default');
	}
	function savePosition(force) {
		if (!audio || audio.duration === 0 || !isFinite(audio.duration)) return;
		const now = Date.now();
		if (!force && now - lastPositionSaveAt < 2500) return;
		lastPositionSaveAt = now;
		try {
			localStorage.setItem(getReportKey(), JSON.stringify({
				trackIndex: currentIndex,
				slug: tracks[currentIndex] ? tracks[currentIndex].slug : null,
				time: audio.currentTime,
				voice: currentVoice,
				variant: currentVariant,
				savedAt: now,
			}));
		} catch (e) { /* quota / disabled */ }
	}
	function loadPosition() {
		try {
			const raw = localStorage.getItem(getReportKey());
			if (!raw) return null;
			const data = JSON.parse(raw);
			if (typeof data !== 'object' || data === null) return null;
			// Validate against current tracks so changes to the report don't
			// produce a nonsense resume.
			if (typeof data.slug !== 'string') return null;
			const idx = findTrackIndexBySlug(data.slug);
			if (idx < 0) return null;
			// Older saved blobs predate voice/variant fields. Return null for
			// those fields so the caller keeps whatever the global preference
			// (STORAGE_KEY / VARIANT_KEY) said — otherwise an old save would
			// silently override the user's current dropdown choice.
			const savedVoice = data.voice === 'male' || data.voice === 'female' ? data.voice : null;
			const savedVariant = data.variant === 'brief' || data.variant === 'elaborate' ? data.variant : null;
			return {
				trackIndex: idx,
				time: Number.isFinite(data.time) ? data.time : 0,
				voice: savedVoice,
				variant: savedVariant,
			};
		} catch (e) { return null; }
	}

	audio.addEventListener('timeupdate', function () {
		updateProgress();
		document.dispatchEvent(new CustomEvent('audio-timeupdate', {
			detail: { currentTime: audio.currentTime, duration: audio.duration },
		}));
		savePosition(false);
	});

	// Save on pause and before the page unloads, in addition to the
	// throttled timeupdate saves.
	audio.addEventListener('pause', function () { savePosition(true); });
	window.addEventListener('pagehide', function () { savePosition(true); });
	window.addEventListener('beforeunload', function () { savePosition(true); });

	audio.addEventListener('play', function () { setPlayingState(true); });
	audio.addEventListener('pause', function () { setPlayingState(false); });

	audio.addEventListener('ended', function () {
		document.dispatchEvent(new CustomEvent('audio-ended'));
		// Auto-advance to next part
		const next = currentIndex + 1;
		if (next < tracks.length) {
			loadTrack(next, { autoplay: true });
		} else {
			setPlayingState(false);
			audio.currentTime = 0;
			const pf = document.getElementById('audio-progress-fill');
			const ct = document.getElementById('audio-current');
			if (pf) pf.style.width = '0%';
			if (ct) ct.textContent = '0:00';
		}
	});

	audio.addEventListener('error', function () {
		const e = audio.error;
		console.warn('[ReportAudioPlayer] Failed to load:', audio.src,
			'code:', e ? e.code : 'unknown');
	});

	// -------------------------------------------------------------- //
	document.addEventListener('click', function (e) {
		if (e.target.closest('#audio-play-btn')) {
			if (audio.paused) {
				// If the page loaded with a heading hash, the first play
				// should start at that heading's timestamp, not at 0.
				if (pendingInitialSeek != null && audio.currentTime < 0.5) {
					try { audio.currentTime = pendingInitialSeek; } catch (_) {}
					pendingInitialSeek = null;
				}
				audio.play().catch((err) => console.warn('[ReportAudioPlayer] Play blocked:', err));
			} else {
				audio.pause();
			}
		}
		if (e.target.closest('#audio-skip-btn'))         skipToNext();
		if (e.target.closest('#audio-prev-btn'))         skipToPrev();
		if (e.target.closest('#audio-section-next-btn')) skipToNextSection();
		if (e.target.closest('#audio-section-prev-btn')) skipToPrevSection();
		if (e.target.closest('#audio-speed-down'))       setSpeedIndex(speedIndex - 1);
		if (e.target.closest('#audio-speed-up'))         setSpeedIndex(speedIndex + 1);
		// Tap on the speed display cycles speeds forward. Desktop users
		// have +/- buttons; mobile has only the display (the steppers
		// are hidden in that breakpoint), so this is the only way for
		// them to change rate.
		if (e.target.closest('#audio-speed-display')) {
			const next = speedIndex >= speeds.length - 1 ? 0 : speedIndex + 1;
			setSpeedIndex(next);
		}

		// Heading "play from here" button
		const seekBtn = e.target.closest ? e.target.closest('.heading-seek-btn') : null;
		if (seekBtn) {
			e.preventDefault();
			e.stopPropagation();
			seekToHeading(seekBtn.dataset.partSlug, seekBtn.dataset.cueId);
			return;
		}

		// Voice dropdown — toggle on the trigger, select on a menu item,
		// close when the user clicks outside the wrapper entirely.
		if (e.target.closest('#audio-voice-btn')) {
			e.preventDefault();
			toggleVoiceMenu();
			return;
		}
		const voiceItem = e.target.closest ? e.target.closest('#audio-voice-menu button[data-voice-key]') : null;
		if (voiceItem) {
			setVoice(voiceItem.getAttribute('data-voice-key'));
			return;
		}
		if (e.target.closest('#audio-variant-btn')) {
			e.preventDefault();
			toggleVariantMenu();
			return;
		}
		const variantItem = e.target.closest ? e.target.closest('#audio-variant-menu button[data-variant-key]') : null;
		if (variantItem) {
			setVariant(variantItem.getAttribute('data-variant-key'));
			return;
		}
		if (!e.target.closest('.audio-voice-menu-wrap')) {
			closeVoiceMenu();
			closeVariantMenu();
		}

		// Clicking a sidebar TOC link also switches the audio track to that
		// part. The browser still handles the hash anchor scroll — we just
		// swap tracks underneath. If audio was playing, keep playing; if not,
		// just cue the new track for play-readiness.
		var tocLink = e.target.closest ? e.target.closest('.report-toc-link') : null;
		if (tocLink) {
			var slug = tocLink.getAttribute('data-part-slug');
			if (slug) {
				for (var ti = 0; ti < tracks.length; ti++) {
					if (tracks[ti].slug === slug && ti !== currentIndex) {
						var wasPlaying = !audio.paused && audio.currentTime > 0;
						loadTrack(ti, { autoplay: wasPlaying });
						break;
					}
				}
			}
		}
	});

	// Close voice menu on Escape
	document.addEventListener('keydown', function (e) {
		if (e.key === 'Escape') {
			closeVoiceMenu();
			closeVariantMenu();
		}
	});

	// Progress bar click-to-seek
	function seekToPercent(pct) {
		if (!audio.duration) return;
		audio.currentTime = (pct / 100) * audio.duration;
		updateProgress();
	}

	function getClickPercent(e) {
		const bar = document.getElementById('audio-progress-bar');
		if (!bar) return 0;
		const rect = bar.getBoundingClientRect();
		const x = (e.clientX !== undefined ? e.clientX : e.touches[0].clientX) - rect.left;
		return Math.max(0, Math.min(100, (x / rect.width) * 100));
	}

	let isSeeking = false;
	document.addEventListener('mousedown', function (e) {
		if (!e.target.closest('#audio-progress-bar')) return;
		e.preventDefault();
		isSeeking = true;
		seekToPercent(getClickPercent(e));
	});
	document.addEventListener('mousemove', function (e) {
		if (!isSeeking) return;
		seekToPercent(getClickPercent(e));
	});
	document.addEventListener('mouseup', function () { isSeeking = false; });

	const progressBar = document.getElementById('audio-progress-bar');
	if (progressBar) {
		progressBar.addEventListener('touchstart', function (e) {
			e.preventDefault();
			seekToPercent(getClickPercent(e));
		}, { passive: false });
		progressBar.addEventListener('touchmove', function (e) {
			e.preventDefault();
			seekToPercent(getClickPercent(e));
		}, { passive: false });
		progressBar.addEventListener('keydown', function (e) {
			if (!audio.duration) return;
			const step = (e.shiftKey ? 30 : 5);
			if (e.key === 'ArrowLeft') {
				audio.currentTime = Math.max(0, audio.currentTime - step);
				e.preventDefault();
			} else if (e.key === 'ArrowRight') {
				audio.currentTime = Math.min(audio.duration, audio.currentTime + step);
				e.preventDefault();
			}
		});
	}

	// Scroll-driven active part: keep ToC + player title in sync when the
	// user scrolls manually. Does NOT seek the audio — just the highlight.
	const partSections = Array.from(document.querySelectorAll('.report-part'));
	// Update the URL hash in place so copying the URL captures the
	// section the reader is currently on. Uses replaceState so the
	// back button stays clean. No hashchange event fires for
	// replaceState, so this will not retrigger track swaps.
	function syncHashToSection(sectionEl) {
		if (!sectionEl) return;
		const id = sectionEl.id;
		if (!id) return;
		const newHash = '#' + id;
		if (window.location.hash === newHash) return;
		history.replaceState(null, '', window.location.pathname + window.location.search + newHash);
	}

	if (partSections.length && 'IntersectionObserver' in window) {
		const io = new IntersectionObserver((entries) => {
			// Pick the entry with the largest intersection ratio so the hash
			// tracks the section actually dominating the viewport, not just
			// whichever crossed the threshold last.
			let best = null;
			entries.forEach((entry) => {
				if (!entry.isIntersecting) return;
				if (!best || entry.intersectionRatio > best.intersectionRatio) best = entry;
			});
			if (!best) return;
			const slug = best.target.getAttribute('data-part-slug');
			if (!slug) return;
			updateTocHighlight(slug);
			syncHashToSection(best.target);
		}, { rootMargin: '-20% 0px -60% 0px', threshold: [0, 0.25, 0.5, 0.75, 1] });
		partSections.forEach((s) => io.observe(s));
	}

	// When the audio advances into a new part (auto-advance, skip, sidebar
	// click), also sync the hash so the URL stays accurate even if the
	// reader has not scrolled.
	document.addEventListener('audio-part-change', function (e) {
		if (!e || !e.detail || !e.detail.slug) return;
		const section = document.querySelector('section[data-part-slug="' + e.detail.slug + '"]');
		if (section) syncHashToSection(section);
	});

	// -------------------------------------------------------------- //
	// Init — but don't interrupt any audio already playing from a previous
	// page. Check whether the persistent <audio> is already playing a track
	// from THIS report; if so, just reattach the UI. Otherwise load part 1.
	updateVoiceLabel();
	updateVoiceMenuChecked();
	updateVariantLabel();
	updateVariantMenuChecked();
	setSpeedIndex(speedIndex);

	function findTrackIndexByUrl(url) {
		if (!url) return -1;
		for (let i = 0; i < tracks.length; i++) {
			const t = tracks[i];
			const urls = [
				resolveTrackUrl(t.audio, 'female', 'brief'),
				resolveTrackUrl(t.audio, 'female', 'elaborate'),
				resolveTrackUrl(t.audio, 'male', 'brief'),
				resolveTrackUrl(t.audio, 'male', 'elaborate'),
			];
			if (urls.indexOf(url) >= 0) return i;
		}
		return -1;
	}

	function findTrackIndexBySlug(slug) {
		if (!slug) return -1;
		for (let i = 0; i < tracks.length; i++) {
			if (tracks[i].slug === slug) return i;
		}
		return -1;
	}

	// Resolve the current URL hash to a concrete target:
	//   { trackIdx, partSlug, element, cueId }
	//
	// The hash can be:
	//   1. A section's title slug (e.g. #how-it-thinks) — the <section>'s id.
	//   2. A heading inside a part (e.g. #validate, from rehype-slug).
	//   3. A legacy #part-{filename} link.
	//
	// For case 2 we also return the heading's h-N cueId so the caller can
	// seek the audio to the corresponding cue start. For cases 1 and 3,
	// cueId is null and playback should start at the beginning of the part.
	function resolveHashTarget() {
		const raw = (window.location.hash || '').replace(/^#/, '');
		if (!raw) return null;

		// Legacy #part-{filename-slug}
		const legacy = raw.match(/^part-(.+)$/);
		if (legacy) {
			const idx = findTrackIndexBySlug(legacy[1]);
			if (idx >= 0) {
				return { trackIdx: idx, partSlug: tracks[idx].slug, element: null, cueId: null };
			}
		}

		// id lookup — can resolve to the section itself or a heading inside it
		const el = document.getElementById(raw);
		if (!el) return null;
		const section = el.closest('[data-part-slug]');
		if (!section) return null;
		const partSlug = section.getAttribute('data-part-slug');
		const trackIdx = findTrackIndexBySlug(partSlug);
		if (trackIdx < 0) return null;

		// If the element itself IS the section, no specific cue — start from 0.
		if (el === section) {
			return { trackIdx, partSlug, element: el, cueId: null };
		}
		// Heading anchored by rehype-slug — find the h-N the paragraph-ids
		// plugin stamped on the same element.
		const cueId = el.getAttribute('data-audio-h');
		return { trackIdx, partSlug, element: el, cueId: cueId || null };
	}

	// -------------------------------------------------------------- //
	// Seek-to-heading — every h2/h3/h4 in the report gets a hover
	// "play from here" button. Clicking jumps the audio to that
	// heading's cue in the part's VTT and starts playback. If the
	// heading lives in a different part than what's currently loaded,
	// swap tracks first then seek once metadata is ready.
	// -------------------------------------------------------------- //

	function parseVttForCueStart(text, cueId) {
		const lines = text.replace(/\r/g, '').split('\n');
		for (let i = 0; i < lines.length; i++) {
			const m = lines[i].match(/(\d+:\d+:\d+\.\d+)\s*-->/);
			if (m && lines[i + 1] && lines[i + 1].trim() === cueId) {
				const parts = m[1].split(':');
				return parseInt(parts[0], 10) * 3600 + parseInt(parts[1], 10) * 60 + parseFloat(parts[2]);
			}
		}
		return null;
	}

	// Return every heading cue's start time, in document order. Used by
	// the section skip buttons so the reader can jump between h2s within
	// a part.
	function parseVttForHeadings(text) {
		const headings = [];
		const lines = text.replace(/\r/g, '').split('\n');
		for (let i = 0; i < lines.length; i++) {
			const m = lines[i].match(/(\d+:\d+:\d+\.\d+)\s*-->/);
			if (!m) continue;
			const body = (lines[i + 1] || '').trim();
			if (/^h-\d+$/.test(body)) {
				const parts = m[1].split(':');
				const start = parseInt(parts[0], 10) * 3600 + parseInt(parts[1], 10) * 60 + parseFloat(parts[2]);
				headings.push({ id: body, start: start });
			}
		}
		return headings;
	}

	function fetchVttHeadings(vttUrl) {
		if (vttCache[vttUrl]) {
			return Promise.resolve(parseVttForHeadings(vttCache[vttUrl]));
		}
		return fetch(vttUrl).then(function (r) { return r.text(); }).then(function (text) {
			vttCache[vttUrl] = text;
			return parseVttForHeadings(text);
		});
	}

	const vttCache = Object.create(null);
	function fetchVttCueStart(vttUrl, cueId) {
		if (vttCache[vttUrl]) {
			return Promise.resolve(parseVttForCueStart(vttCache[vttUrl], cueId));
		}
		return fetch(vttUrl).then(function (r) { return r.text(); }).then(function (text) {
			vttCache[vttUrl] = text;
			return parseVttForCueStart(text, cueId);
		});
	}

	async function seekToHeading(partSlug, cueId) {
		const targetIdx = findTrackIndexBySlug(partSlug);
		if (targetIdx < 0) return;
		const track = tracks[targetIdx];
		const vttUrl = resolveTrackUrl(track.vtt, currentVoice, currentVariant);
		const needSwap = targetIdx !== currentIndex;
		if (needSwap) loadTrack(targetIdx, { autoplay: true });

		let start;
		try { start = await fetchVttCueStart(vttUrl, cueId); }
		catch (_) { start = null; }
		if (start == null) {
			// Heading cue not found in VTT — start of part is the best fallback
			start = 0;
		}

		const applySeek = () => {
			try { audio.currentTime = start; } catch (_) { /* no-op */ }
			audio.play().catch(function () { /* autoplay blocked */ });
		};

		if (needSwap) {
			const onReady = function () {
				audio.removeEventListener('loadedmetadata', onReady);
				applySeek();
			};
			audio.addEventListener('loadedmetadata', onReady);
		} else {
			applySeek();
		}
	}

	// Inject a "play from here" button into every heading carrying
	// data-audio-h, so hover reveals a small play badge.
	function wireHeadingSeekButtons() {
		const heads = document.querySelectorAll('.report-part [data-audio-h]');
		heads.forEach(function (h) {
			if (h.querySelector('.heading-seek-btn')) return;
			const section = h.closest('[data-part-slug]');
			if (!section) return;
			const partSlug = section.getAttribute('data-part-slug');
			const cueId = h.getAttribute('data-audio-h');
			if (!partSlug || !cueId) return;

			const btn = document.createElement('button');
			btn.type = 'button';
			btn.className = 'heading-seek-btn';
			btn.setAttribute('aria-label', 'Play from this section');
			btn.setAttribute('title', 'Play from here');
			btn.dataset.partSlug = partSlug;
			btn.dataset.cueId = cueId;
			btn.innerHTML =
				'<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" width="14" height="14">' +
				'<path d="M8 5v14l11-7z"/></svg>';
			h.insertBefore(btn, h.firstChild);
		});
	}
	wireHeadingSeekButtons();
	document.addEventListener('astro:page-load', wireHeadingSeekButtons);

	const srcNow = audio.src || '';
	const matched = findTrackIndexByUrl(srcNow);
	if (matched >= 0) {
		// Audio is already playing a track from this report. Re-sync UI.
		currentIndex = matched;
		const t = tracks[matched];
		// Recover voice + variant from whichever URL matches the current src.
		const voiceVariantPairs = [
			['female', 'brief'], ['female', 'elaborate'],
			['male', 'brief'],   ['male', 'elaborate'],
		];
		for (let p = 0; p < voiceVariantPairs.length; p++) {
			const [v, vv] = voiceVariantPairs[p];
			if (resolveTrackUrl(t.audio, v, vv) === srcNow) {
				currentVoice = v;
				currentVariant = vv;
				break;
			}
		}
		try {
			localStorage.setItem(STORAGE_KEY, currentVoice);
			localStorage.setItem(VARIANT_KEY, currentVariant);
		} catch (e) { /* blocked */ }
		updateVoiceLabel();
		updateVariantLabel();
		updateTitle(t);
		updateTocHighlight(t.slug);
		showPlayer();
		setPlayingState(!audio.paused);
		if (audio.duration) {
			const de = document.getElementById('audio-duration');
			if (de) de.textContent = formatTime(audio.duration);
			updateProgress();
		}
		// Let AudioSync know which part is active so it loads the VTT
		const vttUrlNow = resolveTrackUrl(t.vtt, currentVoice, currentVariant);
		const syncData = document.getElementById('audio-sync-data');
		if (syncData) {
			syncData.setAttribute('data-vtt-url', vttUrlNow);
			syncData.setAttribute('data-part-slug', t.slug);
		}
		document.dispatchEvent(new CustomEvent('audio-part-change', {
			detail: { slug: t.slug, vttUrl: vttUrlNow, index: matched },
		}));
	} else if (!audio.paused && audio.currentTime > 0) {
		// Audio is playing something else (e.g. a journal entry). Don't
		// interrupt — just keep the player visible so the user keeps control.
		showPlayer();
		setPlayingState(true);
	} else {
		// Fresh visit — honour a hash target if present. A section hash cues
		// that part from the start; a heading hash cues the part AND queues
		// a seek to the heading's cue once metadata is ready. Otherwise
		// restore the reader's last position from localStorage so a
		// refresh or revisit picks up where they left off.
		// No autoplay on first load — wait for the user to hit play.
		const target = resolveHashTarget();
		if (target) {
			loadTrack(target.trackIdx, { autoplay: false });

			// Browsers apply scroll-to-hash once, early during parse — before
			// our inline script mounts the player and adds body padding for
			// it. On a sticky-header page, the hash target often ends up
			// either off-screen or stuck at the top. Re-scroll it into view
			// ourselves after layout settles so the reader actually lands
			// on the section they asked for.
			const targetEl = target.element || document.getElementById(window.location.hash.slice(1));
			if (targetEl) {
				requestAnimationFrame(function () {
					requestAnimationFrame(function () {
						targetEl.scrollIntoView({ behavior: 'auto', block: 'start' });
					});
				});
			}

			if (target.cueId) {
				// Fetch the VTT for this track and remember the start offset
				// so the first play jumps there instead of starting at 0.
				const targetVtt = resolveTrackUrl(tracks[target.trackIdx].vtt, currentVoice, currentVariant);
				fetchVttCueStart(targetVtt, target.cueId)
					.then(function (start) {
						if (start != null) pendingInitialSeek = start;
					})
					.catch(function () { /* best effort */ });
			}
		} else {
			const saved = loadPosition();
			if (saved) {
				// Voice + variant come from the global preference (STORAGE_KEY
				// / VARIANT_KEY) — the per-report save only restores which
				// part you were on and where in it. Old per-report blobs
				// should never silently downgrade a user's current choice.
				loadTrack(saved.trackIndex, { autoplay: false });
				// Queue the saved time for the first play; seek on loadedmetadata.
				if (saved.time > 1) {
					const applyResume = function () {
						try { audio.currentTime = saved.time; } catch (_) {}
						audio.removeEventListener('loadedmetadata', applyResume);
					};
					audio.addEventListener('loadedmetadata', applyResume);
				}
			} else {
				loadTrack(0, { autoplay: false });
			}
		}
	}

	// If the user navigates via hash while the page is loaded — back/forward,
	// clicking an in-page part link in the sidebar, or clicking a heading
	// anchor in the prose — swap the track and (for heading targets) seek.
	window.addEventListener('hashchange', function () {
		const target = resolveHashTarget();
		if (!target) return;
		const wasPlaying = !audio.paused && audio.currentTime > 0;
		if (target.cueId) {
			// seekToHeading handles the cross-part case and plays after seek
			seekToHeading(target.partSlug, target.cueId);
		} else if (target.trackIdx !== currentIndex) {
			loadTrack(target.trackIdx, { autoplay: wasPlaying });
		}
	});
})();
</script>
