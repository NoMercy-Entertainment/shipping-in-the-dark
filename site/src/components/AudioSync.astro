---
/**
 * AudioSync — synchronized paragraph highlighting + auto-scroll
 *
 * Parses a VTT file where each cue identifies a prose paragraph.
 * On timeupdate, highlights the active paragraph and scrolls it into view.
 *
 * Cue matching priority:
 *   1. section:slug  → document.getElementById(slug)  (legacy heading match)
 *   2. p-N pattern   → document.getElementById('p-N') (deterministic ID match)
 *   3. Text fuzzy    → prefix + word-overlap scoring   (fallback for old VTTs)
 */
interface Props {
	vttUrl?: string;
	partSlug?: string;
}

const { vttUrl = '', partSlug = '' } = Astro.props;
const present = vttUrl || partSlug !== undefined;
---

{present && (
	<div
		data-vtt-url={vttUrl}
		data-part-slug={partSlug}
		id="audio-sync-data"
	></div>
)}

<style is:global>
/* ------------------------------------------------------------------ */
/* Active paragraph highlight                                           */
/* ------------------------------------------------------------------ */

.prose p.audio-active,
.prose li.audio-active {
	position: relative;
	border-left: 3px solid var(--color-accent-400);
	padding: 0.55em 1em 0.55em 1em;
	margin-left: -1em;
	margin-right: -1em;
	background-color: oklch(0.765 0.177 163.223 / 0.06);
	border-radius: 0 6px 6px 0;
	transition:
		border-color 0.2s ease,
		background-color 0.2s ease,
		padding 0.2s ease,
		margin 0.2s ease;
}

/* <li> already sits inside a list with its own left padding — pull the
   highlight flush with the list marker rather than extending into the
   surrounding prose. */
.prose li.audio-active {
	margin-left: -1.5em;
	padding-left: 1.5em;
}

html.light .prose p.audio-active,
html.light .prose li.audio-active {
	border-left-color: var(--color-accent-700);
	background-color: oklch(0.48 0.13 163 / 0.07);
}

/* ------------------------------------------------------------------ */
/* Active heading highlight (legacy + section fallback)                */
/* ------------------------------------------------------------------ */

.prose h2.audio-active,
.prose h3.audio-active {
	position: relative;
}

.prose h2.audio-active::before,
.prose h3.audio-active::before {
	content: '';
	position: absolute;
	left: -1.5rem;
	top: 0;
	bottom: 0;
	width: 3px;
	background: var(--color-accent-400);
	border-radius: 2px;
}

html.light .prose h2.audio-active::before,
html.light .prose h3.audio-active::before {
	background: var(--color-accent-700);
}

.prose .audio-active .heading-anchor {
	color: var(--color-accent-400) !important;
}

html.light .prose .audio-active .heading-anchor {
	color: var(--color-accent-700) !important;
}
</style>

<script is:inline>
(function () {

	// ------------------------------------------------------------------ //
	// State                                                                //
	// ------------------------------------------------------------------ //

	/** @type {{ start: number, end: number, element: Element|null, section: string|null }[]} */
	var cues = [];
	var loaded = false;
	var activeElement = null;
	var activeTocSlug = null;
	var currentPartSlug = '';
	var currentVttUrl = '';
	// Active code-block pan state. When a code-N cue starts, we kick off a
	// requestAnimationFrame loop that eases window.scrollY from "top of pre
	// aligned with header" to "bottom of pre above player" over the cue
	// duration. A new cue (or audio end) cancels the pan.
	var codePanRaf = null;
	var codePanEl = null;

	// ------------------------------------------------------------------ //
	// Text normalization — strips markdown artifacts, lowercases,          //
	// collapses whitespace, removes punctuation. Used for fuzzy matching.  //
	// ------------------------------------------------------------------ //

	function normalize(text) {
		return text
			.toLowerCase()
			// strip markdown bold/italic markers
			.replace(/\*{1,3}|_{1,3}/g, '')
			// strip inline links — keep link text, ditch URL
			.replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
			// strip HTML tags
			.replace(/<[^>]+>/g, '')
			// strip punctuation (keep letters, digits, whitespace)
			.replace(/[^\w\s]/g, ' ')
			// collapse whitespace
			.replace(/\s+/g, ' ')
			.trim();
	}

	/** Extract first N words from a normalized string */
	function firstWords(text, n) {
		return text.split(' ').slice(0, n).join(' ');
	}

	// ------------------------------------------------------------------ //
	// VTT parser                                                           //
	// ------------------------------------------------------------------ //

	function parseTimestamp(ts) {
		var parts = ts.split(':');
		return parseInt(parts[0]) * 3600 + parseInt(parts[1]) * 60 + parseFloat(parts[2]);
	}

	/**
	 * Parse VTT text into raw cue objects.
	 * @returns {{ start: number, end: number, text: string, section: string|null, elementId: string|null }[]}
	 *
	 * elementId is set when the cue body is a bare p-N id reference.
	 * section   is set for legacy section:slug cues.
	 * text      carries the spoken text for fuzzy-matched cues.
	 */
	function parseVTT(text) {
		var lines = text.replace(/\r/g, '').split('\n');
		var result = [];
		var i = 0;

		// Skip WEBVTT header line(s)
		while (i < lines.length && !lines[i].match(/^\d+$/)) i++;

		while (i < lines.length) {
			if (!lines[i].match(/^\d+$/)) { i++; continue; }

			i++; // step past cue number

			var timeMatch = lines[i] && lines[i].match(
				/(\d+:\d+:\d+\.\d+)\s*-->\s*(\d+:\d+:\d+\.\d+)/
			);
			if (!timeMatch) { i++; continue; }

			var start = parseTimestamp(timeMatch[1]);
			var end   = parseTimestamp(timeMatch[2]);
			i++;

			var cueLines = [];
			while (i < lines.length && lines[i].trim() !== '') {
				cueLines.push(lines[i].trim());
				i++;
			}
			var cueText = cueLines.join(' ');

			// Legacy section: prefix support
			if (cueText.startsWith('section:')) {
				result.push({ start: start, end: end, text: '', section: cueText.replace('section:', ''), elementId: null });
			// Deterministic element ID references: p-N (paragraph), h-N (heading), i-N (image)
			} else if (/^p-\d+$/.test(cueText)) {
				result.push({ start: start, end: end, text: '', section: null, elementId: cueText });
			} else if (/^h-\d+$/.test(cueText)) {
				result.push({ start: start, end: end, text: '', section: null, elementId: cueText, isHeading: true });
			} else if (/^code-\d+$/.test(cueText)) {
				result.push({ start: start, end: end, text: '', section: null, elementId: cueText, isCode: true });
			} else if (/^i-\d+$/.test(cueText)) {
				result.push({ start: start, end: end, text: '', section: null, elementId: cueText, isImage: true });
			// Unmatched cues (prefixed with --) — skip, no scroll
			} else if (cueText.startsWith('--')) {
				result.push({ start: start, end: end, text: '', section: null, elementId: null });
			} else {
				result.push({ start: start, end: end, text: cueText, section: null, elementId: null });
			}
		}

		return result;
	}

	// ------------------------------------------------------------------ //
	// Scope helpers — when a part slug is set (report pages), element      //
	// lookups are scoped to [data-part-slug="{slug}"] to avoid ID            //
	// collisions across parts on a merged single-page report.                //
	// ------------------------------------------------------------------ //

	function getScopeRoot() {
		if (currentPartSlug) {
			// Must match the section element, not a TOC link that also carries
			// data-part-slug. Prefer the id'd section, which is unique.
			var scoped = document.getElementById('part-' + currentPartSlug)
				|| document.querySelector('section[data-part-slug="' + currentPartSlug + '"]');
			if (scoped) return scoped;
		}
		return null;
	}

	function lookupById(id) {
		var scope = getScopeRoot();
		if (scope) {
			// querySelector with an ID selector is scoped to descendants of scope
			var escaped = id.replace(/"/g, '\\"');
			return scope.querySelector('[id="' + escaped + '"]');
		}
		return document.getElementById(id);
	}

	function lookupHeading(id) {
		var scope = getScopeRoot();
		var sel = '[data-audio-h="' + id + '"]';
		return scope ? scope.querySelector(sel) : document.querySelector(sel);
	}

	function lookupImage(id) {
		var scope = getScopeRoot();
		var sel = '[data-audio-i="' + id + '"]';
		return scope ? scope.querySelector(sel) : document.querySelector(sel);
	}

	// ------------------------------------------------------------------ //
	// Paragraph matching — run once after VTT + DOM are both ready         //
	// ------------------------------------------------------------------ //

	/**
	 * For each raw cue, resolve it to a DOM element.
	 *
	 * Matching pipeline:
	 *
	 * 1. section:slug cues  → document.getElementById(slug)  (legacy heading match)
	 * 2. elementId cues     → document.getElementById(elementId)  (direct p-N lookup)
	 * 3. Text-based cues    → fuzzy match against .prose paragraphs (old VTTs)
	 *    a. Exact prefix: first 8 normalized words of cue === first 8 of paragraph.
	 *    b. Word-overlap scoring: bag-of-words, threshold 0.75 (<4 words) or 0.4.
	 */
	function buildCueMap(rawCues) {
		var proseEl = null;
		var scopedRoot = getScopeRoot();
		if (scopedRoot) {
			// Report mode: the scope root IS the part section, and the prose is inside
			proseEl = scopedRoot.querySelector('.prose') || scopedRoot;
		} else {
			// Entry mode: use the last .prose (first one is header metadata)
			var proseEls = document.querySelectorAll('.prose');
			proseEl = proseEls.length > 0 ? proseEls[proseEls.length - 1] : null;
		}
		if (!proseEl) return rawCues.map(function(c) {
			return { start: c.start, end: c.end, element: null, section: c.section };
		});

		// Collect all paragraphs with both the normalized prefix (fast path)
		// and the full normalized word set (overlap scoring fallback).
		// Only built when there are text-based cues that need fuzzy matching.
		var paraData = null;
		function getParaData() {
			if (paraData) return paraData;
			var paragraphs = Array.from(proseEl.querySelectorAll('p'));
			paraData = paragraphs.map(function(p) {
				var norm = normalize(p.textContent || '');
				var words = norm.split(' ').filter(Boolean);
				// Build a plain object for O(1) membership checks during overlap scoring
				var wordSet = {};
				for (var wi = 0; wi < words.length; wi++) wordSet[words[wi]] = true;
				return { el: p, prefix: firstWords(norm, 8), wordSet: wordSet };
			});
			return paraData;
		}

		// Derive section heading for a matched paragraph element
		function deriveSectionSlug(match) {
			var prev = match.previousElementSibling;
			while (prev) {
				if (prev.matches('h2[id], h3[id]')) return prev.id;
				prev = prev.previousElementSibling;
			}
			// If the immediate sibling scan fails, walk up the parent chain
			var node = match;
			while (node && node !== proseEl) {
				node = node.parentElement;
				if (!node) break;
				var heading = node.querySelector('h2[id], h3[id]');
				if (heading) return heading.id;
			}
			return null;
		}

		// For each cue, find best paragraph match
		return rawCues.map(function(cue) {
			// 1. Legacy section: cues — resolve by heading ID, no paragraph element
			if (cue.section) {
				return { start: cue.start, end: cue.end, element: lookupById(cue.section), section: cue.section };
			}

			// 2. Deterministic element reference — p-N, h-N, i-N, or code-N
			if (cue.elementId) {
				var el = null;
				var isHeading = false;
				var isCode = false;
				if (cue.elementId.startsWith('p-')) {
					el = lookupById(cue.elementId);
				} else if (cue.elementId.startsWith('h-')) {
					el = lookupHeading(cue.elementId);
					isHeading = true;
				} else if (cue.elementId.startsWith('code-')) {
					var scope = getScopeRoot() || document;
					el = scope.querySelector('[data-audio-code="' + cue.elementId + '"]');
					isCode = true;
				} else if (cue.elementId.startsWith('i-')) {
					el = lookupImage(cue.elementId);
					if (el) el = el.closest('p') || el.parentElement || el;
				}
				var sectionSlug = el ? deriveSectionSlug(el) : null;
				return {
					start: cue.start, end: cue.end,
					element: el, section: sectionSlug,
					isHeading: isHeading, isCode: isCode,
				};
			}

			// 3. Text-based fuzzy matching — fallback for VTTs without p-N ids
			if (!cue.text) return { start: cue.start, end: cue.end, element: null, section: null };

			var data = getParaData();
			var normCue = normalize(cue.text);
			var cuePrefix = firstWords(normCue, 8);
			var cueWords = normCue.split(' ').filter(Boolean);

			// ---- Fast path: exact first-8-word prefix match ----
			var match = null;
			for (var i = 0; i < data.length; i++) {
				if (data[i].prefix === cuePrefix) {
					match = data[i].el;
					break;
				}
			}

			// ---- Fallback: word-overlap bag-of-words scoring ----
			// TTS scripts frequently add preamble ("Here's the short version.")
			// or rephrase slightly ("Entry one" vs "Entry 001"). Counting how
			// many cue words appear anywhere in the paragraph catches these cases
			// where prefix comparison fails completely.
			if (!match && cueWords.length >= 3) {
				var threshold = cueWords.length < 6 ? 0.75 : 0.4;
				var bestScore = 0;
				var bestEl = null;

				for (var j = 0; j < data.length; j++) {
					var hits = 0;
					for (var k = 0; k < cueWords.length; k++) {
						if (data[j].wordSet[cueWords[k]]) hits++;
					}
					var score = hits / cueWords.length;
					if (score > bestScore) {
						bestScore = score;
						bestEl = data[j].el;
					}
				}

				if (bestScore >= threshold) match = bestEl;
			}

			var fuzzySection = match ? deriveSectionSlug(match) : null;
			return { start: cue.start, end: cue.end, element: match, section: fuzzySection };
		});
	}

	// ------------------------------------------------------------------ //
	// Active cue lookup — simple linear scan (cues are ~100-300 items,    //
	// well within perf budget for 60fps timeupdate)                        //
	// ------------------------------------------------------------------ //

	// Return the cue the listener is currently "on": the cue whose range
	// covers currentTime, OR — during silent pauses between cues — the most
	// recent cue that has already started. Keeps the highlight stable
	// through [pause:Nms] silences instead of flickering off and on, and
	// eliminates the CSS transition lag that made the state feel late.
	function findActiveCue(currentTime) {
		var active = null;
		for (var i = 0; i < cues.length; i++) {
			if (currentTime >= cues[i].start && currentTime < cues[i].end) {
				return cues[i];
			}
			if (cues[i].start <= currentTime) active = cues[i];
		}
		return active;
	}

	// ------------------------------------------------------------------ //
	// Highlight + scroll                                                   //
	// ------------------------------------------------------------------ //

	function applyHighlight(cue) {
		var el = cue ? cue.element : null;
		var slug = cue ? cue.section : null;

		// Expose the current cue id on the audio-sync-data element so other
		// components (ReportAudioPlayer's voice swap) can re-anchor to the
		// same spoken cue when the absolute time no longer maps cleanly —
		// different voices say the same paragraph at different paces.
		var syncData = document.getElementById('audio-sync-data');
		if (syncData) {
			var cueId = '';
			if (el && el.id && /^p-\d+$/.test(el.id)) cueId = el.id;
			else if (el && el.getAttribute && el.getAttribute('data-audio-h')) cueId = el.getAttribute('data-audio-h');
			if (cueId !== (syncData.getAttribute('data-active-cue') || '')) {
				syncData.setAttribute('data-active-cue', cueId);
			}
		}

		// Paragraph highlight
		if (el !== activeElement) {
			if (activeElement) {
				activeElement.classList.remove('audio-active');
			}
			if (el) {
				el.classList.add('audio-active');
			}
			activeElement = el;

			// Auto-scroll behavior:
			// - Headings and code cues always realign to the top of the
			//   "safe area" (between the 88px sticky header and the 64px
			//   audio player), because a new section / code block always
			//   feels right anchored at the top.
			// - Paragraphs only scroll if they would otherwise be clipped
			//   by the header, the player, or off-screen entirely; they
			//   land centered within the safe area.
			//
			// block: 'center' / 'start' do not respect scroll-padding-top
			// reliably across browsers, so we compute the scroll target
			// ourselves from getBoundingClientRect + the sticky offsets.
			if (el) {
				if (cue && cue.isCode) {
					startCodePan(el, cue.start, cue.end);
				} else if (cue && cue.isHeading) {
					stopCodePan();
					scrollIntoSafeView(el, 'start');
				} else {
					stopCodePan();
					var rect = el.getBoundingClientRect();
					var header = 88;
					var footer = 64;
					var vh = window.innerHeight;
					var needsScroll = rect.top < header || rect.bottom > vh - footer;

					// If this paragraph is immediately followed by a <pre> code
					// block, check the combined rectangle — the narration
					// usually references the code, so we want the code visible
					// while the paragraph is highlighted.
					var nextEl = el.nextElementSibling;
					var followingPre = (nextEl && nextEl.tagName === 'PRE') ? nextEl : null;
					if (followingPre) {
						var preRect = followingPre.getBoundingClientRect();
						var combinedBottom = preRect.bottom;
						var combinedTop = rect.top;
						if (combinedTop < header || combinedBottom > vh - footer) {
							// Align the paragraph to the top of the safe area so
							// the <pre> below gets room — far more useful than
							// centering the paragraph and cutting off the code.
							scrollIntoSafeView(el, 'start');
							return;
						}
					}

					// If this paragraph immediately follows a <pre> code
					// block, the narration is usually describing that
					// code. Keep the code on screen as long as possible:
					// align the paragraph to the BOTTOM of the safe area
					// so the pre above stays visible above it.
					var prevEl = el.previousElementSibling;
					var precedingPre = (prevEl && prevEl.tagName === 'PRE') ? prevEl : null;
					if (precedingPre && needsScroll) {
						scrollIntoSafeView(el, 'end');
						return;
					}

					if (needsScroll) {
						scrollIntoSafeView(el, 'center');
					}
				}
			}
		}

		// ToC highlight — only update when the section actually changes
		if (slug !== activeTocSlug) {
			activeTocSlug = slug;
			var tocLinks = document.querySelectorAll('.toc-link');
			for (var i = 0; i < tocLinks.length; i++) {
				var link = tocLinks[i];
				if (slug && link.getAttribute('data-heading') === slug) {
					link.classList.add('active');
				} else {
					link.classList.remove('active');
				}
			}
		}
	}

	// Scroll el so it lands between the sticky 88px site header and the
	// 64px audio player at the bottom. mode:
	//   'start'  — align the element's top to the safe-top edge
	//   'center' — center the element within the safe band
	//   'end'    — align the element's bottom to the safe-bottom edge
	//              (keeps whatever is above the element visible longer)
	// If the element is taller than the safe band, align its top anyway.
	function scrollIntoSafeView(el, mode) {
		if (!el) return;
		var rect = el.getBoundingClientRect();
		var scrollY = window.scrollY || window.pageYOffset || 0;
		var safeTop = 88;
		var safeBottom = window.innerHeight - 64;
		var safeHeight = Math.max(1, safeBottom - safeTop);

		var target;
		if (mode === 'center' && rect.height <= safeHeight) {
			var elCenter = rect.top + rect.height / 2;
			var safeCenter = safeTop + safeHeight / 2;
			target = scrollY + (elCenter - safeCenter);
		} else if (mode === 'end' && rect.height <= safeHeight) {
			target = scrollY + rect.bottom - safeBottom;
		} else {
			target = scrollY + rect.top - safeTop;
		}
		window.scrollTo({ top: Math.max(0, target), behavior: 'smooth' });
	}

	function stopCodePan() {
		if (codePanRaf != null) {
			cancelAnimationFrame(codePanRaf);
			codePanRaf = null;
		}
		codePanEl = null;
	}

	function startCodePan(el, cueStart, cueEnd) {
		stopCodePan();
		if (!el) return;
		codePanEl = el;

		var header = 88;
		var footer = 64;
		var vh = window.innerHeight;
		var visibleHeight = vh - header - footer;

		// Jump the code block's top just under the sticky header first.
		var rect = el.getBoundingClientRect();
		var startY = window.scrollY + rect.top - header;
		window.scrollTo({ top: startY, behavior: 'smooth' });

		// If the block fits in the viewport, we're done — no pan needed.
		if (rect.height <= visibleHeight + 4) return;

		// Pan down to the bottom of the block over the remaining cue time.
		var extraToPan = rect.height - visibleHeight;

		// Give the smooth scroll a moment to settle before we start panning.
		var audioEl = document.getElementById('sitd-global-audio');
		var panStartTs = null;
		var delay = 350;

		function tick(ts) {
			if (codePanEl !== el) return;
			if (panStartTs === null) panStartTs = ts;
			// Sync to actual audio position so pausing pauses the pan.
			var currentTime = audioEl ? audioEl.currentTime : 0;
			if (currentTime >= cueEnd) { stopCodePan(); return; }
			var elapsed = Math.max(0, currentTime - cueStart);
			var dur = Math.max(0.001, cueEnd - cueStart);
			var t = Math.min(1, elapsed / dur);
			window.scrollTo({ top: startY + extraToPan * t });
			codePanRaf = requestAnimationFrame(tick);
		}

		setTimeout(function () {
			codePanRaf = requestAnimationFrame(tick);
		}, delay);
	}

	function clearHighlight() {
		if (activeElement) {
			activeElement.classList.remove('audio-active');
			activeElement = null;
		}
		activeTocSlug = null;
		var tocLinks = document.querySelectorAll('.toc-link');
		for (var i = 0; i < tocLinks.length; i++) {
			tocLinks[i].classList.remove('active');
		}
	}

	// ------------------------------------------------------------------ //
	// VTT loading                                                          //
	// ------------------------------------------------------------------ //

	function loadVTT(forceUrl, forceSlug) {
		var syncData = document.getElementById('audio-sync-data');
		if (!syncData) return;

		var url = forceUrl !== undefined ? forceUrl : syncData.getAttribute('data-vtt-url');
		var slug = forceSlug !== undefined ? forceSlug : (syncData.getAttribute('data-part-slug') || '');

		if (!url) return;

		// Skip reload if nothing changed
		if (loaded && url === currentVttUrl && slug === currentPartSlug) return;

		currentVttUrl = url;
		currentPartSlug = slug;
		loaded = false;
		cues = [];
		// Clear any previous highlight before the new cues arrive
		if (activeElement) {
			activeElement.classList.remove('audio-active');
			activeElement = null;
		}

		fetch(url)
			.then(function (r) { return r.text(); })
			.then(function (text) {
				var rawCues = parseVTT(text);
				cues = buildCueMap(rawCues);
				loaded = true;
			})
			.catch(function (err) {
				console.warn('[AudioSync] VTT load/parse failed:', err);
			});
	}

	// ------------------------------------------------------------------ //
	// Event wiring                                                         //
	// ------------------------------------------------------------------ //

	document.addEventListener('audio-timeupdate', function (e) {
		if (!loaded) loadVTT();
		if (cues.length === 0) return;
		var active = findActiveCue(e.detail.currentTime);
		applyHighlight(active);
	});

	document.addEventListener('audio-ended', function () {
		stopCodePan();
		clearHighlight();
	});

	// Report player tells us which part is active and which VTT to load
	document.addEventListener('audio-part-change', function (e) {
		if (!e || !e.detail) return;
		loadVTT(e.detail.vttUrl, e.detail.slug);
	});

	// audio-paused: keep highlight visible — user may be reading

	// Re-run matching on page load (DOM may have changed via View Transitions)
	document.addEventListener('astro:page-load', function () {
		loaded = false;
		cues = [];
		activeElement = null;
		activeTocSlug = null;
		currentVttUrl = '';
		currentPartSlug = '';
		loadVTT();
	});

	loadVTT();

})();
</script>
