---
/**
 * AudioSync — synchronized paragraph highlighting + auto-scroll
 *
 * Parses a VTT file where each cue identifies a prose paragraph.
 * On timeupdate, highlights the active paragraph and scrolls it into view.
 *
 * Cue matching priority:
 *   1. section:slug  → document.getElementById(slug)  (legacy heading match)
 *   2. p-N pattern   → document.getElementById('p-N') (deterministic ID match)
 *   3. Text fuzzy    → prefix + word-overlap scoring   (fallback for old VTTs)
 */
interface Props {
	vttUrl?: string;
}

const { vttUrl = '' } = Astro.props;
---

{vttUrl && (
	<div data-vtt-url={vttUrl} id="audio-sync-data"></div>
)}

<style is:global>
/* ------------------------------------------------------------------ */
/* Active paragraph highlight                                           */
/* ------------------------------------------------------------------ */

.prose p.audio-active {
	position: relative;
	border-left: 3px solid var(--color-accent-400);
	padding-left: 0.85em;
	margin-left: -1em;
	background-color: oklch(0.765 0.177 163.223 / 0.06);
	border-radius: 0 4px 4px 0;
	transition:
		border-color 0.25s ease,
		background-color 0.25s ease,
		padding-left 0.25s ease,
		margin-left 0.25s ease;
}

html.light .prose p.audio-active {
	border-left-color: var(--color-accent-700);
	background-color: oklch(0.48 0.13 163 / 0.07);
}

/* ------------------------------------------------------------------ */
/* Active heading highlight (legacy + section fallback)                */
/* ------------------------------------------------------------------ */

.prose h2.audio-active,
.prose h3.audio-active {
	position: relative;
}

.prose h2.audio-active::before,
.prose h3.audio-active::before {
	content: '';
	position: absolute;
	left: -1.5rem;
	top: 0;
	bottom: 0;
	width: 3px;
	background: var(--color-accent-400);
	border-radius: 2px;
}

html.light .prose h2.audio-active::before,
html.light .prose h3.audio-active::before {
	background: var(--color-accent-700);
}

.prose .audio-active .heading-anchor {
	color: var(--color-accent-400) !important;
}

html.light .prose .audio-active .heading-anchor {
	color: var(--color-accent-700) !important;
}
</style>

<script is:inline>
(function () {

	// ------------------------------------------------------------------ //
	// State                                                                //
	// ------------------------------------------------------------------ //

	/** @type {{ start: number, end: number, element: Element|null, section: string|null }[]} */
	var cues = [];
	var loaded = false;
	var activeElement = null;
	var activeTocSlug = null;

	// ------------------------------------------------------------------ //
	// Text normalization — strips markdown artifacts, lowercases,          //
	// collapses whitespace, removes punctuation. Used for fuzzy matching.  //
	// ------------------------------------------------------------------ //

	function normalize(text) {
		return text
			.toLowerCase()
			// strip markdown bold/italic markers
			.replace(/\*{1,3}|_{1,3}/g, '')
			// strip inline links — keep link text, ditch URL
			.replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
			// strip HTML tags
			.replace(/<[^>]+>/g, '')
			// strip punctuation (keep letters, digits, whitespace)
			.replace(/[^\w\s]/g, ' ')
			// collapse whitespace
			.replace(/\s+/g, ' ')
			.trim();
	}

	/** Extract first N words from a normalized string */
	function firstWords(text, n) {
		return text.split(' ').slice(0, n).join(' ');
	}

	// ------------------------------------------------------------------ //
	// VTT parser                                                           //
	// ------------------------------------------------------------------ //

	function parseTimestamp(ts) {
		var parts = ts.split(':');
		return parseInt(parts[0]) * 3600 + parseInt(parts[1]) * 60 + parseFloat(parts[2]);
	}

	/**
	 * Parse VTT text into raw cue objects.
	 * @returns {{ start: number, end: number, text: string, section: string|null, elementId: string|null }[]}
	 *
	 * elementId is set when the cue body is a bare p-N id reference.
	 * section   is set for legacy section:slug cues.
	 * text      carries the spoken text for fuzzy-matched cues.
	 */
	function parseVTT(text) {
		var lines = text.replace(/\r/g, '').split('\n');
		var result = [];
		var i = 0;

		// Skip WEBVTT header line(s)
		while (i < lines.length && !lines[i].match(/^\d+$/)) i++;

		while (i < lines.length) {
			if (!lines[i].match(/^\d+$/)) { i++; continue; }

			i++; // step past cue number

			var timeMatch = lines[i] && lines[i].match(
				/(\d+:\d+:\d+\.\d+)\s*-->\s*(\d+:\d+:\d+\.\d+)/
			);
			if (!timeMatch) { i++; continue; }

			var start = parseTimestamp(timeMatch[1]);
			var end   = parseTimestamp(timeMatch[2]);
			i++;

			var cueLines = [];
			while (i < lines.length && lines[i].trim() !== '') {
				cueLines.push(lines[i].trim());
				i++;
			}
			var cueText = cueLines.join(' ');

			// Legacy section: prefix support
			if (cueText.startsWith('section:')) {
				result.push({ start: start, end: end, text: '', section: cueText.replace('section:', ''), elementId: null });
			// Deterministic p-N id reference — the entire cue body is just the element id
			} else if (/^p-\d+$/.test(cueText)) {
				result.push({ start: start, end: end, text: '', section: null, elementId: cueText });
			// Unmatched cues from rewrite-vtt-ids (prefixed with --) — skip, no scroll
			} else if (cueText.startsWith('--')) {
				result.push({ start: start, end: end, text: '', section: null, elementId: null });
			} else {
				result.push({ start: start, end: end, text: cueText, section: null, elementId: null });
			}
		}

		return result;
	}

	// ------------------------------------------------------------------ //
	// Paragraph matching — run once after VTT + DOM are both ready         //
	// ------------------------------------------------------------------ //

	/**
	 * For each raw cue, resolve it to a DOM element.
	 *
	 * Matching pipeline:
	 *
	 * 1. section:slug cues  → document.getElementById(slug)  (legacy heading match)
	 * 2. elementId cues     → document.getElementById(elementId)  (direct p-N lookup)
	 * 3. Text-based cues    → fuzzy match against .prose paragraphs (old VTTs)
	 *    a. Exact prefix: first 8 normalized words of cue === first 8 of paragraph.
	 *    b. Word-overlap scoring: bag-of-words, threshold 0.75 (<4 words) or 0.4.
	 */
	function buildCueMap(rawCues) {
		// Use the last .prose element — the first one is the header metadata
		var proseEls = document.querySelectorAll('.prose');
		var proseEl = proseEls.length > 0 ? proseEls[proseEls.length - 1] : null;
		if (!proseEl) return rawCues.map(function(c) {
			return { start: c.start, end: c.end, element: null, section: c.section };
		});

		// Collect all paragraphs with both the normalized prefix (fast path)
		// and the full normalized word set (overlap scoring fallback).
		// Only built when there are text-based cues that need fuzzy matching.
		var paraData = null;
		function getParaData() {
			if (paraData) return paraData;
			var paragraphs = Array.from(proseEl.querySelectorAll('p'));
			paraData = paragraphs.map(function(p) {
				var norm = normalize(p.textContent || '');
				var words = norm.split(' ').filter(Boolean);
				// Build a plain object for O(1) membership checks during overlap scoring
				var wordSet = {};
				for (var wi = 0; wi < words.length; wi++) wordSet[words[wi]] = true;
				return { el: p, prefix: firstWords(norm, 8), wordSet: wordSet };
			});
			return paraData;
		}

		// Derive section heading for a matched paragraph element
		function deriveSectionSlug(match) {
			var prev = match.previousElementSibling;
			while (prev) {
				if (prev.matches('h2[id], h3[id]')) return prev.id;
				prev = prev.previousElementSibling;
			}
			// If the immediate sibling scan fails, walk up the parent chain
			var node = match;
			while (node && node !== proseEl) {
				node = node.parentElement;
				if (!node) break;
				var heading = node.querySelector('h2[id], h3[id]');
				if (heading) return heading.id;
			}
			return null;
		}

		// For each cue, find best paragraph match
		return rawCues.map(function(cue) {
			// 1. Legacy section: cues — resolve by heading ID, no paragraph element
			if (cue.section) {
				return { start: cue.start, end: cue.end, element: document.getElementById(cue.section), section: cue.section };
			}

			// 2. Deterministic p-N id reference — direct getElementById, no fuzzy needed
			if (cue.elementId) {
				var el = document.getElementById(cue.elementId);
				var sectionSlug = el ? deriveSectionSlug(el) : null;
				return { start: cue.start, end: cue.end, element: el, section: sectionSlug };
			}

			// 3. Text-based fuzzy matching — fallback for VTTs without p-N ids
			if (!cue.text) return { start: cue.start, end: cue.end, element: null, section: null };

			var data = getParaData();
			var normCue = normalize(cue.text);
			var cuePrefix = firstWords(normCue, 8);
			var cueWords = normCue.split(' ').filter(Boolean);

			// ---- Fast path: exact first-8-word prefix match ----
			var match = null;
			for (var i = 0; i < data.length; i++) {
				if (data[i].prefix === cuePrefix) {
					match = data[i].el;
					break;
				}
			}

			// ---- Fallback: word-overlap bag-of-words scoring ----
			// TTS scripts frequently add preamble ("Here's the short version.")
			// or rephrase slightly ("Entry one" vs "Entry 001"). Counting how
			// many cue words appear anywhere in the paragraph catches these cases
			// where prefix comparison fails completely.
			if (!match && cueWords.length >= 3) {
				var threshold = cueWords.length < 6 ? 0.75 : 0.4;
				var bestScore = 0;
				var bestEl = null;

				for (var j = 0; j < data.length; j++) {
					var hits = 0;
					for (var k = 0; k < cueWords.length; k++) {
						if (data[j].wordSet[cueWords[k]]) hits++;
					}
					var score = hits / cueWords.length;
					if (score > bestScore) {
						bestScore = score;
						bestEl = data[j].el;
					}
				}

				if (bestScore >= threshold) match = bestEl;
			}

			var fuzzySection = match ? deriveSectionSlug(match) : null;
			return { start: cue.start, end: cue.end, element: match, section: fuzzySection };
		});
	}

	// ------------------------------------------------------------------ //
	// Active cue lookup — simple linear scan (cues are ~100-300 items,    //
	// well within perf budget for 60fps timeupdate)                        //
	// ------------------------------------------------------------------ //

	function findActiveCue(currentTime) {
		for (var i = 0; i < cues.length; i++) {
			if (currentTime >= cues[i].start && currentTime < cues[i].end) {
				return cues[i];
			}
		}
		return null;
	}

	// ------------------------------------------------------------------ //
	// Highlight + scroll                                                   //
	// ------------------------------------------------------------------ //

	function applyHighlight(cue) {
		var el = cue ? cue.element : null;
		var slug = cue ? cue.section : null;

		// Paragraph highlight
		if (el !== activeElement) {
			if (activeElement) activeElement.classList.remove('audio-active');
			if (el) el.classList.add('audio-active');
			activeElement = el;

			// Auto-scroll: bring active paragraph into view if out of viewport
			if (el) {
				var rect = el.getBoundingClientRect();
				var vh   = window.innerHeight;
				// Scroll if the element is outside the middle band (80px–65% of viewport)
				if (rect.top < 80 || rect.bottom > vh * 0.85) {
					el.scrollIntoView({ behavior: 'smooth', block: 'center' });
				}
			}
		}

		// ToC highlight — only update when the section actually changes
		if (slug !== activeTocSlug) {
			activeTocSlug = slug;
			var tocLinks = document.querySelectorAll('.toc-link');
			for (var i = 0; i < tocLinks.length; i++) {
				var link = tocLinks[i];
				if (slug && link.getAttribute('data-heading') === slug) {
					link.classList.add('active');
				} else {
					link.classList.remove('active');
				}
			}
		}
	}

	function clearHighlight() {
		if (activeElement) {
			activeElement.classList.remove('audio-active');
			activeElement = null;
		}
		activeTocSlug = null;
		var tocLinks = document.querySelectorAll('.toc-link');
		for (var i = 0; i < tocLinks.length; i++) {
			tocLinks[i].classList.remove('active');
		}
	}

	// ------------------------------------------------------------------ //
	// VTT loading                                                          //
	// ------------------------------------------------------------------ //

	function loadVTT() {
		var syncData = document.getElementById('audio-sync-data');
		if (!syncData || loaded) return;

		var url = syncData.getAttribute('data-vtt-url');
		if (!url) return;

		fetch(url)
			.then(function (r) { return r.text(); })
			.then(function (text) {
				var rawCues = parseVTT(text);
				cues = buildCueMap(rawCues);
				loaded = true;
			})
			.catch(function (err) {
				console.warn('[AudioSync] VTT load/parse failed:', err);
			});
	}

	// ------------------------------------------------------------------ //
	// Event wiring                                                         //
	// ------------------------------------------------------------------ //

	document.addEventListener('audio-timeupdate', function (e) {
		if (!loaded) loadVTT();
		if (cues.length === 0) return;
		var active = findActiveCue(e.detail.currentTime);
		applyHighlight(active);
	});

	document.addEventListener('audio-ended', function () {
		clearHighlight();
	});

	// audio-paused: keep highlight visible — user may be reading

	// Re-run matching on page load (DOM may have changed via View Transitions)
	document.addEventListener('astro:page-load', function () {
		loaded = false;
		cues = [];
		activeElement = null;
		activeTocSlug = null;
		loadVTT();
	});

	loadVTT();

})();
</script>
