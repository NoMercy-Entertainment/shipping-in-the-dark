---
interface Props {
	tags: string[];
}

const { tags } = Astro.props;
---

{tags.length > 0 && (
	<div class="mt-8 flex flex-wrap gap-2">
		{tags.map((tag) => (
			<a
				href={`/tag/${tag}`}
				class="inline-flex items-center rounded-full bg-surface-800 px-3 py-1 text-xs font-medium text-surface-400 no-underline transition-colors hover:bg-surface-700 hover:text-surface-200 light:bg-surface-200 light:text-surface-700 light:hover:bg-surface-300 light:hover:text-surface-900"
			>
				#{tag}
			</a>
		))}
	</div>
)}
