---
// Search component using Pagefind
---

<div id="search-container" class="search-container">
	<button
		id="search-trigger"
		type="button"
		class="search-trigger"
		aria-label="Search entries"
	>
		<svg class="search-trigger-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
			<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
		</svg>
		<span class="search-trigger-label">Search</span>
		<kbd class="search-trigger-kbd" aria-hidden="true">/</kbd>
	</button>
</div>

<div id="search-overlay" role="dialog" aria-modal="true" aria-label="Search">
	<div class="search-backdrop"></div>
	<div class="search-modal">
		<div class="search-modal-head">
			<div id="search-widget"></div>
			<button
				type="button"
				class="search-close"
				aria-label="Close search"
				id="search-close-btn"
			>
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<line x1="18" y1="6" x2="6" y2="18"></line>
					<line x1="6" y1="6" x2="18" y2="18"></line>
				</svg>
			</button>
		</div>
		<div class="search-hint" aria-hidden="true">
			<span>Esc to close</span>
			<span>↑ ↓ to navigate</span>
			<span>⏎ to open</span>
		</div>
	</div>
</div>

<style is:global>
	/* Trigger button in the header ----------------------------------- */
	.search-trigger {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.4rem 0.75rem;
		font-size: 0.875rem;
		font-family: var(--font-ui, system-ui);
		color: var(--color-surface-400);
		background: var(--color-surface-900);
		border: 1px solid var(--color-surface-800);
		border-radius: 8px;
		cursor: pointer;
		transition: color 0.15s ease, border-color 0.15s ease, background-color 0.15s ease;
		min-width: 12rem;
	}
	html.light .search-trigger {
		color: var(--color-surface-600);
		background: var(--color-surface-100);
		border-color: var(--color-surface-200);
	}
	.search-trigger:hover {
		color: var(--color-surface-100);
		border-color: var(--color-surface-600);
	}
	html.light .search-trigger:hover {
		color: var(--color-surface-900);
		border-color: var(--color-surface-400);
	}
	.search-trigger:focus-visible {
		outline: 2px solid var(--color-accent-400);
		outline-offset: 2px;
	}
	.search-trigger-icon {
		width: 16px;
		height: 16px;
		flex-shrink: 0;
	}
	.search-trigger-label {
		flex: 1;
		text-align: left;
	}
	.search-trigger-kbd {
		font-family: var(--font-mono, ui-monospace);
		font-size: 0.75rem;
		padding: 0.1rem 0.4rem;
		background: var(--color-surface-800);
		border: 1px solid var(--color-surface-700);
		border-radius: 4px;
		color: var(--color-surface-400);
		line-height: 1;
	}
	html.light .search-trigger-kbd {
		background: var(--color-surface-200);
		border-color: var(--color-surface-300);
		color: var(--color-surface-700);
	}
	@media (max-width: 640px) {
		.search-trigger {
			min-width: 0;
			padding: 0.45rem;
		}
		.search-trigger-label,
		.search-trigger-kbd {
			display: none;
		}
	}

	/* Overlay + modal --------------------------------------------------- */
	#search-overlay {
		display: none;
		position: fixed;
		inset: 0;
		z-index: 200;
	}
	#search-overlay.active {
		display: block;
	}
	.search-backdrop {
		position: fixed;
		inset: 0;
		background: rgba(0, 0, 0, 0.65);
		backdrop-filter: blur(6px);
		-webkit-backdrop-filter: blur(6px);
	}

	.search-modal {
		position: fixed;
		top: max(5vh, 1rem);
		left: 50%;
		transform: translateX(-50%);
		width: calc(100% - 2rem);
		max-width: 40rem;
		/* Modal itself never scrolls. The results list inside does. That
		   keeps the input sticky at the top where the cursor is. */
		max-height: min(80vh, 46rem);
		display: flex;
		flex-direction: column;
		background: var(--color-surface-900);
		border: 1px solid var(--color-surface-700);
		border-radius: 12px;
		overflow: hidden;
		box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
	}
	html.light .search-modal {
		background: white;
		border-color: var(--color-surface-200);
		box-shadow: 0 20px 60px rgba(0, 0, 0, 0.18);
	}

	.search-modal-head {
		position: relative;
		border-bottom: 1px solid var(--color-surface-800);
		flex-shrink: 0;
	}
	html.light .search-modal-head {
		border-bottom-color: var(--color-surface-200);
	}

	.search-close {
		position: absolute;
		top: 50%;
		right: 1rem;
		transform: translateY(-50%);
		width: 28px;
		height: 28px;
		display: flex;
		align-items: center;
		justify-content: center;
		border: none;
		background: transparent;
		color: var(--color-surface-500);
		cursor: pointer;
		border-radius: 6px;
		transition: color 0.15s ease, background-color 0.15s ease;
		z-index: 2;
	}
	.search-close:hover {
		color: var(--color-surface-100);
		background: var(--color-surface-800);
	}
	html.light .search-close:hover {
		color: var(--color-surface-900);
		background: var(--color-surface-200);
	}
	.search-close svg {
		width: 16px;
		height: 16px;
	}

	.search-hint {
		display: flex;
		gap: 1.25rem;
		padding: 0.5rem 1rem;
		font-size: 0.7rem;
		color: var(--color-surface-500);
		background: var(--color-surface-900);
		border-top: 1px solid var(--color-surface-800);
		flex-shrink: 0;
	}
	html.light .search-hint {
		background: var(--color-surface-100);
		border-top-color: var(--color-surface-200);
		color: var(--color-surface-600);
	}
	@media (max-width: 480px) {
		.search-hint { display: none; }
	}

	/* Pagefind UI overrides --------------------------------------------- */
	:root {
		--pagefind-ui-scale: 1;
		--pagefind-ui-primary: #4ade80;
		--pagefind-ui-text: #fafafa;
		--pagefind-ui-background: transparent;
		--pagefind-ui-border: transparent;
		--pagefind-ui-tag: #38383f;
		--pagefind-ui-border-width: 0;
		--pagefind-ui-border-radius: 0;
		--pagefind-ui-font: 'Atkinson Hyperlegible', system-ui, sans-serif;
	}
	html.light {
		--pagefind-ui-primary: #2d8c5b;
		--pagefind-ui-text: #1e1d22;
		--pagefind-ui-tag: #e9e8ed;
	}

	/* Pagefind injects its widget into #search-widget. Style the input to
	   feel like a proper app search field — big, focused, and without the
	   distracting default border/rounded pill. */
	#search-widget .pagefind-ui__search-input {
		width: 100%;
		padding: 1rem 3rem 1rem 3rem;
		border: 0;
		border-radius: 0;
		background: transparent;
		font-size: 1rem;
		line-height: 1.3;
		color: var(--color-surface-50);
		outline: none;
		box-shadow: none;
	}
	html.light #search-widget .pagefind-ui__search-input {
		color: var(--color-surface-900);
	}
	#search-widget .pagefind-ui__search-input::placeholder {
		color: var(--color-surface-500);
	}
	/* Replace the default magnifier with our own, positioned at the start. */
	#search-widget .pagefind-ui__form {
		position: relative;
	}
	#search-widget .pagefind-ui__form::before {
		content: '';
		position: absolute;
		left: 1rem;
		top: 50%;
		width: 18px;
		height: 18px;
		transform: translateY(-50%);
		background: currentColor;
		color: var(--color-surface-500);
		mask: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><circle cx='11' cy='11' r='8'/><line x1='21' y1='21' x2='16.65' y2='16.65'/></svg>") center / contain no-repeat;
		-webkit-mask: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><circle cx='11' cy='11' r='8'/><line x1='21' y1='21' x2='16.65' y2='16.65'/></svg>") center / contain no-repeat;
		pointer-events: none;
	}
	#search-widget .pagefind-ui__search-clear {
		right: 3rem;
		top: 50%;
		transform: translateY(-50%);
		background: transparent;
		color: var(--color-surface-500);
		border: none;
		cursor: pointer;
		padding: 0.25rem 0.5rem;
		font-size: 0.8rem;
	}
	#search-widget .pagefind-ui__search-clear:hover {
		color: var(--color-surface-100);
	}

	/* Results live in their own scroll container, so the input stays put. */
	#search-widget .pagefind-ui__drawer {
		max-height: calc(min(80vh, 46rem) - 8rem);
		overflow-y: auto;
		padding: 0.5rem 1rem 1rem;
	}
	#search-widget .pagefind-ui__drawer:not(.pagefind-ui__hidden) {
		display: block;
	}
	#search-widget .pagefind-ui__results-area {
		padding: 0;
	}
	#search-widget .pagefind-ui__message {
		padding: 0.75rem 0;
		color: var(--color-surface-400);
		font-size: 0.85rem;
	}
	#search-widget .pagefind-ui__result {
		padding: 0.9rem 0;
		border-bottom: 1px solid var(--color-surface-800);
	}
	html.light #search-widget .pagefind-ui__result {
		border-bottom-color: var(--color-surface-200);
	}
	#search-widget .pagefind-ui__result:last-child {
		border-bottom: none;
	}
	#search-widget .pagefind-ui__result-title {
		font-size: 1rem;
		margin: 0 0 0.25rem 0;
	}
	#search-widget .pagefind-ui__result-link {
		color: var(--color-accent-400) !important;
		text-decoration: none;
	}
	#search-widget .pagefind-ui__result-link:hover {
		text-decoration: underline;
	}
	html.light #search-widget .pagefind-ui__result-link {
		color: var(--color-accent-700) !important;
	}
	#search-widget .pagefind-ui__result-excerpt {
		color: var(--color-surface-300);
		font-size: 0.875rem;
		line-height: 1.5;
	}
	html.light #search-widget .pagefind-ui__result-excerpt {
		color: var(--color-surface-700);
	}
	#search-widget mark {
		background: var(--color-accent-400);
		color: var(--color-surface-950);
		padding: 0 2px;
		border-radius: 2px;
	}
	html.light #search-widget mark {
		background: var(--color-accent-600);
		color: white;
	}
</style>

<script is:inline>
(function() {
	const trigger = document.getElementById('search-trigger');
	const overlay = document.getElementById('search-overlay');
	const closeBtn = document.getElementById('search-close-btn');
	let loaded = false;

	async function openSearch() {
		overlay.classList.add('active');
		document.body.style.overflow = 'hidden';

		if (!loaded) {
			try {
				if (!window.PagefindUI) {
					await new Promise((resolve, reject) => {
						const script = document.createElement('script');
						script.src = '/pagefind/pagefind-ui.js';
						script.onload = resolve;
						script.onerror = reject;
						document.head.appendChild(script);
					});
				}
				if (window.PagefindUI) {
					new window.PagefindUI({
						element: '#search-widget',
						showSubResults: true,
						showImages: false,
						autofocus: true,
						resetStyles: false,
						placeholder: 'Search entries, team, and reports...',
					});
					loaded = true;
				}
			} catch (err) {
				document.getElementById('search-widget').innerHTML =
					'<p style="padding:1rem;color:var(--color-surface-400)">Search index not built yet. Run <code>npm run build</code> first.</p>';
			}
		}

		setTimeout(() => {
			const input = overlay.querySelector('.pagefind-ui__search-input');
			if (input) input.focus();
		}, 50);
	}

	function closeSearch() {
		overlay.classList.remove('active');
		document.body.style.overflow = '';
	}

	trigger?.addEventListener('click', openSearch);
	closeBtn?.addEventListener('click', closeSearch);
	document.querySelector('.search-backdrop')?.addEventListener('click', closeSearch);

	document.addEventListener('keydown', (e) => {
		const isInput = document.activeElement?.tagName === 'INPUT' ||
		                document.activeElement?.tagName === 'TEXTAREA';
		if ((e.key === 'k' && (e.metaKey || e.ctrlKey)) && !isInput) {
			e.preventDefault();
			openSearch();
			return;
		}
		if (e.key === '/' && !isInput && !overlay.classList.contains('active')) {
			e.preventDefault();
			openSearch();
			return;
		}
		if (e.key === 'Escape') closeSearch();
	});
})();
</script>
