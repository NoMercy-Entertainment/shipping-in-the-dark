---
// Search component using Pagefind
---

<div id="search-container" class="search-container">
	<button
		id="search-trigger"
		type="button"
		class="flex items-center gap-2 rounded-lg border border-surface-800 bg-surface-900/50 px-3 py-1.5 text-sm text-surface-500 transition-colors hover:border-surface-600 hover:text-surface-300 light:border-surface-200 light:bg-surface-100/50 light:text-surface-600 light:hover:border-surface-400 light:hover:text-surface-900"
		aria-label="Search entries"
	>
		<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
			<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
		</svg>
		<span class="hidden sm:inline">Search</span>
	</button>
</div>

<div id="search-overlay">
	<div class="search-backdrop"></div>
	<div class="search-modal">
		<div id="search-widget"></div>
	</div>
</div>

<style is:global>
	#search-overlay {
		display: none;
		position: fixed;
		inset: 0;
		z-index: 200;
	}

	#search-overlay.active {
		display: block;
	}

	.search-backdrop {
		position: fixed;
		inset: 0;
		background: rgba(0, 0, 0, 0.6);
		backdrop-filter: blur(4px);
		-webkit-backdrop-filter: blur(4px);
	}

	.search-modal {
		position: fixed;
		top: 10vh;
		left: 50%;
		transform: translateX(-50%);
		width: calc(100% - 2rem);
		max-width: 36rem;
		max-height: 75vh;
		overflow-y: auto;
		background: var(--color-surface-900);
		border: 1px solid var(--color-surface-700);
		border-radius: 12px;
		padding: 1rem;
		box-shadow: 0 16px 48px rgba(0, 0, 0, 0.4);
	}

	html.light .search-modal {
		background: white;
		border-color: var(--color-surface-200);
		box-shadow: 0 16px 48px rgba(0, 0, 0, 0.15);
	}

	/* Pagefind UI overrides */
	:root {
		--pagefind-ui-scale: 0.9;
		--pagefind-ui-primary: #4ade80;
		--pagefind-ui-text: #fafafa;
		--pagefind-ui-background: transparent;
		--pagefind-ui-border: #38383f;
		--pagefind-ui-tag: #38383f;
		--pagefind-ui-border-width: 1px;
		--pagefind-ui-border-radius: 8px;
		--pagefind-ui-font: 'Atkinson Hyperlegible', system-ui, sans-serif;
	}

	html.light {
		--pagefind-ui-primary: #2d8c5b;
		--pagefind-ui-text: #1e1d22;
		--pagefind-ui-border: #e9e8ed;
		--pagefind-ui-tag: #e9e8ed;
	}

	.pagefind-ui__result-link {
		color: var(--color-accent-400) !important;
	}

	html.light .pagefind-ui__result-link {
		color: var(--color-accent-700) !important;
	}
</style>

<script is:inline>
(function() {
	const trigger = document.getElementById('search-trigger');
	const overlay = document.getElementById('search-overlay');
	let loaded = false;

	async function openSearch() {
		overlay.classList.add('active');
		document.body.style.overflow = 'hidden';

		if (!loaded) {
			try {
				// Pagefind UI is an IIFE that sets window.PagefindUI
				if (!window.PagefindUI) {
					await new Promise((resolve, reject) => {
						const script = document.createElement('script');
						script.src = '/pagefind/pagefind-ui.js';
						script.onload = resolve;
						script.onerror = reject;
						document.head.appendChild(script);
					});
				}
				if (window.PagefindUI) {
					new window.PagefindUI({
						element: '#search-widget',
						showSubResults: true,
						showImages: false,
					});
					loaded = true;
				}
			} catch (err) {
				document.getElementById('search-widget').innerHTML = '<p style="padding:1em;opacity:0.6">Search is not available. Try again after a full site build.</p>';
			}
		}

		setTimeout(() => {
			const input = overlay.querySelector('.pagefind-ui__search-input');
			if (input) input.focus();
		}, 100);
	}

	function closeSearch() {
		overlay.classList.remove('active');
		document.body.style.overflow = '';
	}

	trigger.addEventListener('click', openSearch);

	document.querySelector('.search-backdrop')?.addEventListener('click', closeSearch);

	document.addEventListener('keydown', (e) => {
		if ((e.key === 'k' && (e.metaKey || e.ctrlKey)) || e.key === '/') {
			if (document.activeElement?.tagName !== 'INPUT' && document.activeElement?.tagName !== 'TEXTAREA') {
				e.preventDefault();
				openSearch();
			}
		}
		if (e.key === 'Escape') closeSearch();
	});
})();
</script>
