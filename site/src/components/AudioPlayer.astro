---
interface Props {
	audioUrl?: string;
	title?: string;
}

const { audioUrl = '', title = '' } = Astro.props;
---

<div
	id="audio-player"
	class="audio-player"
	data-audio-url={audioUrl}
	data-title={title}
	aria-label="Audio player"
	role="region"
>
	<!-- Seekable progress bar sits at the very top of the bar -->
	<div
		id="audio-progress-bar"
		class="audio-progress-bar"
		role="progressbar"
		aria-valuemin="0"
		aria-valuemax="100"
		aria-valuenow="0"
		aria-label="Playback progress"
		tabindex="0"
	>
		<div id="audio-progress-fill" class="audio-progress-fill"></div>
	</div>

	<div class="audio-controls">
		<button
			id="audio-play-btn"
			class="audio-play-btn"
			aria-label="Play"
			type="button"
		>
			<!-- Play icon (shown by default) -->
			<svg id="icon-play" class="audio-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
				<path d="M8 5v14l11-7z" />
			</svg>
			<!-- Pause icon (hidden by default) -->
			<svg id="icon-pause" class="audio-icon hidden" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
				<path d="M6 19h4V5H6zm8-14v14h4V5z" />
			</svg>
		</button>

		<div class="audio-time" aria-live="off">
			<span id="audio-current" class="audio-current">0:00</span>
			<span class="audio-separator" aria-hidden="true">/</span>
			<span id="audio-duration" class="audio-duration">0:00</span>
		</div>

		<div id="audio-title" class="audio-title" aria-label="Now playing">
			{title}
		</div>

		<button
			id="audio-speed-btn"
			class="audio-speed"
			aria-label="Playback speed: 1x"
			type="button"
		>
			1x
		</button>
	</div>
</div>

<!--
	Shared audio-player styles live in src/styles/global.css so both
	AudioPlayer.astro and ReportAudioPlayer.astro pick them up on any
	page, regardless of which component is rendered.
-->

<script is:inline>
(function () {
	'use strict';

	// ------------------------------------------------------------------ //
	// Grab DOM refs                                                         //
	// ------------------------------------------------------------------ //

	var player   = document.getElementById('audio-player');
	var progressBar  = document.getElementById('audio-progress-bar');
	var progressFill = document.getElementById('audio-progress-fill');
	var playBtn  = document.getElementById('audio-play-btn');
	var iconPlay = document.getElementById('icon-play');
	var iconPause = document.getElementById('icon-pause');
	var currentTimeEl = document.getElementById('audio-current');
	var durationEl = document.getElementById('audio-duration');
	var titleEl  = document.getElementById('audio-title');
	var speedBtn = document.getElementById('audio-speed-btn');

	if (!player) return;

	// ------------------------------------------------------------------ //
	// Audio engine — native HTML5 Audio                                    //
	// ------------------------------------------------------------------ //

	// Global persistent <audio> lives in BaseLayout and survives view
	// transitions. Keeps playback continuous when the user navigates.
	var audio = document.getElementById('sitd-global-audio');
	if (!audio) {
		// Fallback for pages that somehow skipped BaseLayout
		audio = new Audio();
		audio.preload = 'metadata';
	}

	var speeds = [0.75, 1, 1.25, 1.5];
	var speedIndex = 1; // start at 1x

	// ------------------------------------------------------------------ //
	// State helpers                                                         //
	// ------------------------------------------------------------------ //

	function showPlayer() {
		var p = document.getElementById('audio-player');
		if (p) p.classList.add('is-visible');
		document.body.classList.add('audio-player-visible');
		document.documentElement.classList.add('audio-player-visible');
	}

	function hidePlayer() {
		var p = document.getElementById('audio-player');
		if (p) p.classList.remove('is-visible');
		document.body.classList.remove('audio-player-visible');
		document.documentElement.classList.remove('audio-player-visible');
	}

	function setPlayingState(playing) {
		var ip = document.getElementById('icon-play');
		var ipa = document.getElementById('icon-pause');
		var pb = document.getElementById('audio-play-btn');
		if (!ip || !ipa || !pb) return;
		if (playing) {
			ip.classList.add('hidden');
			ipa.classList.remove('hidden');
			pb.setAttribute('aria-label', 'Pause');
		} else {
			ip.classList.remove('hidden');
			ipa.classList.add('hidden');
			pb.setAttribute('aria-label', 'Play');
		}
	}

	function formatTime(seconds) {
		if (!isFinite(seconds) || isNaN(seconds)) return '0:00';
		var m = Math.floor(seconds / 60);
		var s = Math.floor(seconds % 60);
		return m + ':' + (s < 10 ? '0' : '') + s;
	}

	function updateProgress() {
		if (!audio.duration) return;
		var pct = (audio.currentTime / audio.duration) * 100;
		var pf = document.getElementById('audio-progress-fill');
		var pb = document.getElementById('audio-progress-bar');
		var ct = document.getElementById('audio-current');
		if (pf) pf.style.width = pct + '%';
		if (pb) pb.setAttribute('aria-valuenow', Math.round(pct));
		if (ct) ct.textContent = formatTime(audio.currentTime);
	}

	// ------------------------------------------------------------------ //
	// Load a track                                                          //
	// ------------------------------------------------------------------ //

	function loadTrack(url, entryTitle) {
		if (!url) {
			hidePlayer();
			return;
		}

		// Reset state visually before loading
		setPlayingState(false);
		var pf = document.getElementById('audio-progress-fill');
		var ct = document.getElementById('audio-current');
		var dt = document.getElementById('audio-duration');
		var tl = document.getElementById('audio-title');
		var sb = document.getElementById('audio-speed-btn');
		if (pf) pf.style.width = '0%';
		if (ct) ct.textContent = '0:00';
		if (dt) dt.textContent = '0:00';
		if (tl) tl.textContent = entryTitle || '';
		speedIndex = 1;
		if (sb) { sb.textContent = '1x'; sb.setAttribute('aria-label', 'Playback speed: 1x'); }
		audio.playbackRate = 1;

		audio.src = url;
		audio.load();
		showPlayer();
	}

	// ------------------------------------------------------------------ //
	// Audio events                                                          //
	// ------------------------------------------------------------------ //

	audio.addEventListener('loadedmetadata', function () {
		var de = document.getElementById('audio-duration');
		if (de) de.textContent = formatTime(audio.duration);
	});

	audio.addEventListener('timeupdate', function() {
		updateProgress();
		document.dispatchEvent(new CustomEvent('audio-timeupdate', { detail: { currentTime: audio.currentTime, duration: audio.duration } }));
	});

	audio.addEventListener('play', function () {
		setPlayingState(true);
	});

	audio.addEventListener('pause', function () {
		setPlayingState(false);
	});

	audio.addEventListener('ended', function () {
		document.dispatchEvent(new CustomEvent('audio-ended'));
		setPlayingState(false);
		audio.currentTime = 0;
		progressFill.style.width = '0%';
		currentTimeEl.textContent = '0:00';
	});

	audio.addEventListener('error', function () {
		var e = audio.error;
		console.warn('[AudioPlayer] Failed to load audio:', audio.src,
			'code:', e ? e.code : 'unknown', 'message:', e ? e.message : 'none');
		hidePlayer();
	});

	// ------------------------------------------------------------------ //
	// Controls                                                              //
	// ------------------------------------------------------------------ //

	// Use event delegation — survives View Transition DOM swaps
	document.addEventListener('click', function (e) {
		if (e.target.closest('#audio-play-btn')) {
			if (audio.paused) {
				audio.play().catch(function (err) {
					console.warn('[AudioPlayer] Play blocked:', err);
				});
			} else {
				audio.pause();
			}
		}
		if (e.target.closest('#audio-speed-btn')) {
			speedIndex = (speedIndex + 1) % speeds.length;
			var rate = speeds[speedIndex];
			audio.playbackRate = rate;
			var label = rate + 'x';
			var btn = document.getElementById('audio-speed-btn');
			if (btn) {
				btn.textContent = label;
				btn.setAttribute('aria-label', 'Playback speed: ' + label);
			}
		}
	});

	// ------------------------------------------------------------------ //
	// Progress bar — click to seek, keyboard support                        //
	// ------------------------------------------------------------------ //

	function seekToPercent(pct) {
		if (!audio.duration) return;
		audio.currentTime = (pct / 100) * audio.duration;
		updateProgress();
	}

	function getClickPercent(e) {
		var bar = document.getElementById('audio-progress-bar');
		if (!bar) return 0;
		var rect = bar.getBoundingClientRect();
		var x = (e.clientX !== undefined ? e.clientX : e.touches[0].clientX) - rect.left;
		return Math.max(0, Math.min(100, (x / rect.width) * 100));
	}

	var isSeeking = false;

	document.addEventListener('mousedown', function (e) {
		if (!e.target.closest('#audio-progress-bar')) return;
		e.preventDefault();
		isSeeking = true;
		seekToPercent(getClickPercent(e));
	});

	document.addEventListener('mousemove', function (e) {
		if (!isSeeking) return;
		seekToPercent(getClickPercent(e));
	});

	document.addEventListener('mouseup', function () {
		isSeeking = false;
	});

	// Touch support
	progressBar.addEventListener('touchstart', function (e) {
		e.preventDefault();
		seekToPercent(getClickPercent(e));
	}, { passive: false });

	progressBar.addEventListener('touchmove', function (e) {
		e.preventDefault();
		seekToPercent(getClickPercent(e));
	}, { passive: false });

	// Keyboard seek: left/right arrows on the progress bar
	progressBar.addEventListener('keydown', function (e) {
		if (!audio.duration) return;
		var step = (e.shiftKey ? 30 : 5); // 5s or 30s with shift
		if (e.key === 'ArrowLeft') {
			audio.currentTime = Math.max(0, audio.currentTime - step);
			e.preventDefault();
		} else if (e.key === 'ArrowRight') {
			audio.currentTime = Math.min(audio.duration, audio.currentTime + step);
			e.preventDefault();
		}
	});

	// ------------------------------------------------------------------ //
	// View Transitions — Astro's SPA-like navigation                        //
	// ------------------------------------------------------------------ //

	function checkCurrentPage() {
		var pagePlayer = document.getElementById('audio-player');
		if (!pagePlayer) return;

		var url   = pagePlayer.getAttribute('data-audio-url') || '';
		var title = pagePlayer.getAttribute('data-title') || '';

		// If the persisted audio is already playing, never interrupt it for
		// navigation. The new page's UI just syncs to whatever is running.
		var isPlaying = !audio.paused && audio.currentTime > 0;

		if (url) {
			// Only load a new track if (a) audio isn't currently playing OR
			// (b) the URL changed and the user hasn't explicitly chosen to
			// keep the previous stream.
			if (url !== audio.src && !isPlaying) {
				loadTrack(url, title);
			} else {
				// Same track, or audio is playing — keep the existing stream.
				// Update the UI title only.
				if (titleEl) titleEl.textContent = title || '';
				showPlayer();
			}
		} else if (isPlaying) {
			// Page has no audio URL, but audio is playing from a previous page.
			// Keep the player visible so the user can still control playback.
			showPlayer();
		} else {
			// No audio running and page has none — hide the player.
			hidePlayer();
		}
	}

	// Note: we do NOT pause the audio on before-swap. The <audio> element is
	// persisted via BaseLayout's transition:persist, so playback continues
	// across navigations. The next page's AudioPlayer / ReportAudioPlayer
	// will re-attach its UI to the same persistent element.

	document.addEventListener('astro:page-load', function () {
		// Re-grab element references after the swap (DOM replaced)
		player       = document.getElementById('audio-player');
		progressBar  = document.getElementById('audio-progress-bar');
		progressFill = document.getElementById('audio-progress-fill');
		playBtn      = document.getElementById('audio-play-btn');
		iconPlay     = document.getElementById('icon-play');
		iconPause    = document.getElementById('icon-pause');
		currentTimeEl = document.getElementById('audio-current');
		durationEl   = document.getElementById('audio-duration');
		titleEl      = document.getElementById('audio-title');
		speedBtn     = document.getElementById('audio-speed-btn');

		if (!player) return;

		// Event listeners use delegation (on document) so no re-attachment needed.

		// Sync visual state if audio was already playing before navigation
		setPlayingState(!audio.paused);
		if (audio.duration) {
			durationEl.textContent = formatTime(audio.duration);
			updateProgress();
		}
		if (speedBtn) {
			speedBtn.textContent = speeds[speedIndex] + 'x';
		}

		checkCurrentPage();
	});

	// ------------------------------------------------------------------ //
	// Initial page load (no view transitions fired yet)                    //
	// ------------------------------------------------------------------ //

	checkCurrentPage();

})();
</script>
