---
/**
 * ArticleSource — small "view source on GitHub" link for each content page.
 *
 * Pass the path to the source markdown or folder RELATIVE to the
 * shipping-in-the-dark repo root (e.g. "entries/2026-04-13-008-the-wrong-filename.md"
 * or "reports/the-effortless-encoder/").
 */
interface Props {
	path: string;
	label?: string;
}

const { path, label = 'View source on GitHub' } = Astro.props;

const BASE = 'https://github.com/NoMercy-Entertainment/shipping-in-the-dark';
// If the path ends in /, link to the folder (tree); otherwise link to the file (blob).
const kind = path.endsWith('/') ? 'tree' : 'blob';
const url = `${BASE}/${kind}/master/${path.replace(/^\/+/, '')}`;
---

<p class="article-source mt-8 text-sm text-surface-500 light:text-surface-600">
	<a
		href={url}
		target="_blank"
		rel="noopener noreferrer"
		class="inline-flex items-center gap-2 no-underline hover:text-accent-400 light:hover:text-accent-700"
	>
		<svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
			<path d="M12 0.296c-6.627 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.387.6.113.819-.258.819-.577 0-.285-.01-1.04-.015-2.04-3.338.725-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.089-.744.083-.729.083-.729 1.205.085 1.838 1.237 1.838 1.237 1.07 1.834 2.807 1.304 3.492.997.108-.775.418-1.305.762-1.604-2.665-.303-5.467-1.332-5.467-5.93 0-1.31.468-2.381 1.236-3.22-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.3 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.29-1.552 3.296-1.23 3.296-1.23.654 1.652.243 2.873.12 3.176.77.839 1.233 1.91 1.233 3.22 0 4.609-2.807 5.624-5.48 5.921.43.372.815 1.102.815 2.222 0 1.604-.015 2.898-.015 3.293 0 .322.216.697.825.577C20.565 22.092 24 17.596 24 12.296c0-6.627-5.373-12-12-12"/>
		</svg>
		<span>{label}</span>
	</a>
</p>
