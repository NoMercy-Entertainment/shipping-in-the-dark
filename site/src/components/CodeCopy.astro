---
/**
 * CodeCopy — global script + styles that add a "copy" button to every
 * rendered `<pre>` code block on the page.
 *
 * Works with shiki-highlighted blocks (wraps the pre in a container,
 * positions the button top-right, swaps to a check mark on success).
 * Re-runs after Astro view transitions so new pages get buttons too.
 */
---

<style is:global>
	.code-copy-wrap {
		position: relative;
	}

	.code-copy-btn {
		position: absolute;
		top: 0.5rem;
		right: 0.5rem;
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		padding: 4px 8px;
		font-family: var(--font-mono);
		font-size: 0.6875rem;
		font-weight: 600;
		line-height: 1;
		color: var(--color-surface-400);
		background-color: var(--color-surface-800);
		border: 1px solid var(--color-surface-700);
		border-radius: 6px;
		cursor: pointer;
		opacity: 0;
		transform: translateY(-2px);
		transition:
			opacity 0.15s ease,
			transform 0.15s ease,
			color 0.15s ease,
			background-color 0.15s ease,
			border-color 0.15s ease;
		outline: none;
		user-select: none;
	}

	html.light .code-copy-btn {
		color: var(--color-surface-600);
		background-color: var(--color-surface-100);
		border-color: var(--color-surface-300);
	}

	.code-copy-wrap:hover .code-copy-btn,
	.code-copy-btn:focus-visible {
		opacity: 1;
		transform: translateY(0);
	}

	.code-copy-btn:hover {
		color: var(--color-surface-100);
		background-color: var(--color-surface-700);
	}

	html.light .code-copy-btn:hover {
		color: var(--color-surface-900);
		background-color: var(--color-surface-200);
	}

	.code-copy-btn:focus-visible {
		outline: 2px solid var(--color-accent-400);
		outline-offset: 2px;
	}

	.code-copy-btn.is-copied {
		color: var(--color-accent-400);
		border-color: var(--color-accent-400);
	}

	html.light .code-copy-btn.is-copied {
		color: var(--color-accent-700);
		border-color: var(--color-accent-700);
	}

	.code-copy-btn .copy-icon,
	.code-copy-btn .check-icon {
		width: 12px;
		height: 12px;
	}

	.code-copy-btn .check-icon {
		display: none;
	}

	.code-copy-btn.is-copied .copy-icon {
		display: none;
	}

	.code-copy-btn.is-copied .check-icon {
		display: inline;
	}
</style>

<script is:inline>
(function () {
	'use strict';

	var COPY_SVG =
		'<svg class="copy-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">' +
		'<rect x="9" y="9" width="13" height="13" rx="2"/>' +
		'<path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/>' +
		'</svg>';
	var CHECK_SVG =
		'<svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">' +
		'<polyline points="20 6 9 17 4 12"/>' +
		'</svg>';

	function addButton(pre) {
		// Skip if already wrapped
		if (pre.parentElement && pre.parentElement.classList.contains('code-copy-wrap')) return;
		// Skip tiny/inline-ish snippets without a code child
		if (!pre.querySelector('code') && !pre.textContent) return;

		var wrap = document.createElement('div');
		wrap.className = 'code-copy-wrap';
		pre.parentNode.insertBefore(wrap, pre);
		wrap.appendChild(pre);

		var btn = document.createElement('button');
		btn.type = 'button';
		btn.className = 'code-copy-btn';
		btn.setAttribute('aria-label', 'Copy code to clipboard');
		btn.innerHTML = COPY_SVG + CHECK_SVG + '<span class="copy-label">Copy</span>';
		wrap.appendChild(btn);
	}

	function collectCodeText(pre) {
		var codeEl = pre.querySelector('code') || pre;
		return codeEl.innerText;
	}

	function flashCopied(btn) {
		btn.classList.add('is-copied');
		var label = btn.querySelector('.copy-label');
		if (label) label.textContent = 'Copied';
		setTimeout(function () {
			btn.classList.remove('is-copied');
			if (label) label.textContent = 'Copy';
		}, 1500);
	}

	function flashFailed(btn) {
		var label = btn.querySelector('.copy-label');
		if (label) label.textContent = 'Failed';
		setTimeout(function () {
			if (label) label.textContent = 'Copy';
		}, 1500);
	}

	function attachAll() {
		var pres = document.querySelectorAll('article pre, main pre, .prose pre');
		for (var i = 0; i < pres.length; i++) addButton(pres[i]);
	}

	// Event delegation survives View Transitions (listeners live on document)
	document.addEventListener('click', function (e) {
		var btn = e.target.closest ? e.target.closest('.code-copy-btn') : null;
		if (!btn) return;
		var wrap = btn.closest('.code-copy-wrap');
		if (!wrap) return;
		var pre = wrap.querySelector('pre');
		if (!pre) return;

		var text = collectCodeText(pre);
		if (navigator.clipboard && navigator.clipboard.writeText) {
			navigator.clipboard.writeText(text).then(
				function () { flashCopied(btn); },
				function () {
					// Fallback: use a hidden textarea
					try {
						var ta = document.createElement('textarea');
						ta.value = text;
						ta.setAttribute('readonly', '');
						ta.style.position = 'absolute';
						ta.style.left = '-9999px';
						document.body.appendChild(ta);
						ta.select();
						document.execCommand('copy');
						document.body.removeChild(ta);
						flashCopied(btn);
					} catch (err) {
						flashFailed(btn);
					}
				}
			);
		} else {
			flashFailed(btn);
		}
	});

	// Initial page + every View Transition swap
	attachAll();
	document.addEventListener('astro:page-load', attachAll);
})();
</script>
