---
interface Props {
	headings: { depth: number; slug: string; text: string }[];
}

const { headings } = Astro.props;
const toc = headings.filter(h => h.depth >= 2 && h.depth <= 3);
---

{toc.length > 0 && (
	<nav id="toc-sidebar" class="toc-sidebar" aria-label="Table of contents">
		<div class="toc-title">On this page</div>
		<ul class="toc-list">
			{toc.map((heading) => (
				<li>
					<a
						href={`#${heading.slug}`}
						data-heading={heading.slug}
						class:list={[
							'toc-link',
							heading.depth === 3 && 'toc-link--nested',
						]}
					>
						{heading.text}
					</a>
				</li>
			))}
		</ul>
	</nav>
)}

<style is:global>
/* Desktop: sticky sidebar */
@media (min-width: 1280px) {
	.toc-sidebar {
		position: fixed;
		top: 5rem;
		right: max(1rem, calc((100vw - 65ch) / 2 - 22rem));
		width: 15rem;
		max-height: calc(100vh - 6rem);
		overflow-y: auto;
		scrollbar-width: thin;
		scrollbar-color: var(--color-surface-700) transparent;
	}
}

/* Below 1280px: collapse into a horizontal bar above the content */
@media (max-width: 1279px) {
	.toc-sidebar {
		margin-bottom: 2rem;
		padding: 1rem 1.25rem;
		border: 1px solid var(--color-surface-800);
		border-radius: 12px;
		max-height: 12rem;
		overflow-y: auto;
	}

	html.light .toc-sidebar {
		border-color: var(--color-surface-200);
	}
}

.toc-title {
	font-size: 0.75rem;
	font-weight: 700;
	text-transform: uppercase;
	letter-spacing: 0.08em;
	color: var(--color-surface-500);
	margin-bottom: 0.75rem;
}

html.light .toc-title {
	color: var(--color-surface-700);
}

.toc-list {
	list-style: none;
	padding: 0;
	margin: 0;
	display: flex;
	flex-direction: column;
	gap: 2px;
}

.toc-link {
	display: block;
	font-size: 0.8125rem;
	line-height: 1.5;
	padding: 0.2em 0.5em;
	border-left: 2px solid transparent;
	color: var(--color-surface-500);
	text-decoration: none;
	transition: color 0.15s ease, border-color 0.15s ease;
	border-radius: 0 4px 4px 0;
}

html.light .toc-link {
	color: var(--color-surface-600);
}

.toc-link:hover {
	color: var(--color-surface-200);
}

html.light .toc-link:hover {
	color: var(--color-surface-900);
}

.toc-link--nested {
	padding-left: 1.25em;
	font-size: 0.75rem;
}

.toc-link.active {
	color: var(--color-accent-400);
	border-left-color: var(--color-accent-400);
}

html.light .toc-link.active {
	color: var(--color-accent-700);
	border-left-color: var(--color-accent-700);
}
</style>

<script is:inline>
(function() {
	const links = document.querySelectorAll('.toc-link');
	if (links.length === 0) return;

	const headingIds = Array.from(links).map(l => l.dataset.heading);

	function updateActive() {
		let activeId = headingIds[0];

		for (const id of headingIds) {
			const el = document.getElementById(id);
			if (!el) continue;
			const rect = el.getBoundingClientRect();
			if (rect.top <= 100) {
				activeId = id;
			}
		}

		links.forEach(link => {
			link.classList.toggle('active', link.dataset.heading === activeId);
		});
	}

	window.addEventListener('scroll', updateActive, { passive: true });
	updateActive();
})();
</script>
