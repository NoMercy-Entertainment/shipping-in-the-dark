---
interface Props {
	headings: { depth: number; slug: string; text: string }[];
}

const { headings } = Astro.props;
const toc = headings.filter(h => h.depth >= 2 && h.depth <= 3);
---

{toc.length > 0 && (
	<nav class="toc mb-8 rounded-xl border border-surface-800 p-5 light:border-surface-200" aria-label="Table of contents">
		<details open>
			<summary class="cursor-pointer text-sm font-bold uppercase tracking-wider text-surface-400 light:text-surface-700 select-none">
				On this page
			</summary>
			<ul class="mt-3 flex flex-col gap-1.5">
				{toc.map((heading) => (
					<li>
						<a
							href={`#${heading.slug}`}
							class:list={[
								'block text-sm no-underline transition-colors hover:text-accent-400 light:hover:text-accent-700',
								heading.depth === 2 ? 'text-surface-300 light:text-surface-700' : 'pl-4 text-surface-500 light:text-surface-600',
							]}
						>
							{heading.text}
						</a>
					</li>
				))}
			</ul>
		</details>
	</nav>
)}
