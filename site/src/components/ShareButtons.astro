---
interface Props {
	title: string;
	url: string;
	prominent?: boolean;
}

const { title, url, prominent = false } = Astro.props;

const encodedUrl = encodeURIComponent(url);
const encodedTitle = encodeURIComponent(title);

const shareLinks = {
	twitter: `https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`,
	linkedin: `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`,
	hn: `https://news.ycombinator.com/submitlink?u=${encodedUrl}&t=${encodedTitle}`,
};

const buttonClass = prominent
	? 'inline-flex items-center justify-center rounded-md p-2 text-surface-400 transition-colors hover:text-accent-400 light:text-surface-600 light:hover:text-accent-600 focus:outline-none focus-visible:ring-2 focus-visible:ring-accent-400'
	: 'inline-flex items-center justify-center rounded-md p-1.5 text-surface-500 transition-colors hover:text-accent-400 light:text-surface-600 light:hover:text-accent-600 focus:outline-none focus-visible:ring-2 focus-visible:ring-accent-400';
---

<div class:list={['flex items-center gap-1', prominent ? 'gap-2' : 'gap-1']}>
	<button
		type="button"
		class={buttonClass}
		data-copy-url={url}
		aria-label="Copy link to clipboard"
		title="Copy link"
	>
		<svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" width={prominent ? 18 : 16} height={prominent ? 18 : 16} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
			<path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
		</svg>
	</button>

	<a
		href={shareLinks.twitter}
		target="_blank"
		rel="noopener noreferrer"
		class={buttonClass}
		aria-label="Share on X (Twitter)"
		title="Share on X"
	>
		<svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" width={prominent ? 18 : 16} height={prominent ? 18 : 16} viewBox="0 0 24 24" fill="currentColor">
			<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.253 5.622 5.91-5.622Zm-1.161 17.52h1.833L7.084 4.126H5.117Z"/>
		</svg>
	</a>

	<a
		href={shareLinks.linkedin}
		target="_blank"
		rel="noopener noreferrer"
		class={buttonClass}
		aria-label="Share on LinkedIn"
		title="Share on LinkedIn"
	>
		<svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" width={prominent ? 18 : 16} height={prominent ? 18 : 16} viewBox="0 0 24 24" fill="currentColor">
			<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
		</svg>
	</a>

	<a
		href={shareLinks.hn}
		target="_blank"
		rel="noopener noreferrer"
		class={buttonClass}
		aria-label="Submit to Hacker News"
		title="Submit to Hacker News"
	>
		<svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" width={prominent ? 18 : 16} height={prominent ? 18 : 16} viewBox="0 0 24 24" fill="currentColor">
			<path d="M0 24V0h24v24H0zM6.951 5.896l4.112 7.708v5.064h1.583v-4.972l4.148-7.799h-1.749l-2.527 4.976c-.027.055-.097.333-.213.831-.033-.144-.064-.27-.094-.378a2.286 2.286 0 0 0-.119-.453l-2.527-4.976H6.951z"/>
		</svg>
	</a>
</div>

<div
	id="copy-tooltip"
	role="status"
	aria-live="polite"
	class="pointer-events-none fixed bottom-6 left-1/2 -translate-x-1/2 rounded-md bg-surface-800 px-3 py-1.5 text-sm text-surface-100 opacity-0 transition-opacity duration-200 light:bg-surface-900 light:text-surface-50"
>
	Copied!
</div>

<script>
(function () {
	function showCopied() {
		const tooltip = document.getElementById('copy-tooltip');
		if (!tooltip) return;
		tooltip.style.opacity = '1';
		setTimeout(() => {
			tooltip.style.opacity = '0';
		}, 1500);
	}

	document.addEventListener('click', function (e) {
		const btn = (e.target as Element).closest('[data-copy-url]') as HTMLElement | null;
		if (!btn) return;
		const url = btn.dataset.copyUrl;
		if (!url) return;
		navigator.clipboard.writeText(url).then(showCopied).catch(() => {
			// Fallback for older browsers
			try {
				const ta = document.createElement('textarea');
				ta.value = url;
				ta.style.position = 'fixed';
				ta.style.opacity = '0';
				document.body.appendChild(ta);
				ta.select();
				document.execCommand('copy');
				document.body.removeChild(ta);
				showCopied();
			} catch (_) {}
		});
	});
})();
</script>
