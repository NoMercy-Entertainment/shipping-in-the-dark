---
interface Props {
	title: string;
	url: string;
	prominent?: boolean;
}

const { title, url, prominent = false } = Astro.props;

const encodedUrl = encodeURIComponent(url);
const encodedTitle = encodeURIComponent(title);
const encodedText = encodeURIComponent(`${title} — ${url}`);

const shareLinks = {
	twitter:  `https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`,
	bluesky:  `https://bsky.app/intent/compose?text=${encodedText}`,
	linkedin: `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`,
	reddit:   `https://www.reddit.com/submit?url=${encodedUrl}&title=${encodedTitle}`,
	hn:       `https://news.ycombinator.com/submitlink?u=${encodedUrl}&t=${encodedTitle}`,
	email:    `mailto:?subject=${encodedTitle}&body=${encodedText}`,
	whatsapp: `https://wa.me/?text=${encodedText}`,
	telegram: `https://t.me/share/url?url=${encodedUrl}&text=${encodedTitle}`,
};

const size = prominent ? 18 : 16;
const btn = prominent
	? 'inline-flex items-center justify-center rounded-md p-2 text-surface-400 transition-colors hover:text-accent-400 light:text-surface-600 light:hover:text-accent-600 focus:outline-none focus-visible:ring-2 focus-visible:ring-accent-400'
	: 'inline-flex items-center justify-center rounded-md p-1.5 text-surface-500 transition-colors hover:text-accent-400 light:text-surface-600 light:hover:text-accent-600 focus:outline-none focus-visible:ring-2 focus-visible:ring-accent-400';
---

<div class:list={['flex flex-wrap items-center', prominent ? 'gap-2' : 'gap-1']} role="group" aria-label="Share this">
	{/* Web Share API — visible on touch devices, falls back to hidden on desktop */}
	<button
		type="button"
		class={`${btn} share-native-btn`}
		data-share-title={title}
		data-share-url={url}
		aria-label="Share via device"
		title="Share"
		hidden
	>
		<svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<circle cx="18" cy="5" r="3"/>
			<circle cx="6" cy="12" r="3"/>
			<circle cx="18" cy="19" r="3"/>
			<line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
			<line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
		</svg>
	</button>

	<button type="button" class={btn} data-copy-url={url} aria-label="Copy link to clipboard" title="Copy link">
		<svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
			<path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
		</svg>
	</button>

	<a href={shareLinks.twitter} target="_blank" rel="noopener noreferrer" class={btn} aria-label="Share on X (Twitter)" title="Share on X">
		<svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" width={size} height={size} viewBox="0 0 24 24" fill="currentColor">
			<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.253 5.622 5.91-5.622Zm-1.161 17.52h1.833L7.084 4.126H5.117Z"/>
		</svg>
	</a>

	<a href={shareLinks.bluesky} target="_blank" rel="noopener noreferrer" class={btn} aria-label="Share on Bluesky" title="Share on Bluesky">
		<svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" width={size} height={size} viewBox="0 0 24 24" fill="currentColor">
			<path d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.813 2.736 3.713 3.66 6.383 3.364-3.908.58-7.378 2.003-2.825 7.08 5.008 5.213 6.87-1.116 7.818-4.324.948 3.208 2.042 9.26 7.712 4.324 4.26-4.942.902-6.5-3.006-7.08 2.671.296 5.57-.628 6.384-3.364.245-.83.624-5.79.624-6.479 0-.688-.139-1.86-.902-2.203-.659-.299-1.664-.621-4.3 1.24C16.045 4.747 13.087 8.686 12 10.8z"/>
		</svg>
	</a>

	<a href={shareLinks.linkedin} target="_blank" rel="noopener noreferrer" class={btn} aria-label="Share on LinkedIn" title="Share on LinkedIn">
		<svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" width={size} height={size} viewBox="0 0 24 24" fill="currentColor">
			<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
		</svg>
	</a>

	<a href={shareLinks.reddit} target="_blank" rel="noopener noreferrer" class={btn} aria-label="Share on Reddit" title="Share on Reddit">
		<svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" width={size} height={size} viewBox="0 0 24 24" fill="currentColor">
			<path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12.2c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 0 0-.231.094.33.33 0 0 0 0 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 0 0 .029-.463.33.33 0 0 0-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 0 0-.232-.095z"/>
		</svg>
	</a>

	<a href={shareLinks.hn} target="_blank" rel="noopener noreferrer" class={btn} aria-label="Submit to Hacker News" title="Submit to Hacker News">
		<svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" width={size} height={size} viewBox="0 0 24 24" fill="currentColor">
			<path d="M0 24V0h24v24H0zM6.951 5.896l4.112 7.708v5.064h1.583v-4.972l4.148-7.799h-1.749l-2.527 4.976c-.027.055-.097.333-.213.831-.033-.144-.064-.27-.094-.378a2.286 2.286 0 0 0-.119-.453l-2.527-4.976H6.951z"/>
		</svg>
	</a>

	<a href={shareLinks.email} class={btn} aria-label="Share via email" title="Email">
		<svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<rect x="2" y="4" width="20" height="16" rx="2"/>
			<path d="m22 7-10 5L2 7"/>
		</svg>
	</a>

	<a href={shareLinks.whatsapp} target="_blank" rel="noopener noreferrer" class={btn} aria-label="Share on WhatsApp" title="WhatsApp">
		<svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" width={size} height={size} viewBox="0 0 24 24" fill="currentColor">
			<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413"/>
		</svg>
	</a>

	<a href={shareLinks.telegram} target="_blank" rel="noopener noreferrer" class={btn} aria-label="Share on Telegram" title="Telegram">
		<svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" width={size} height={size} viewBox="0 0 24 24" fill="currentColor">
			<path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
		</svg>
	</a>
</div>

<div id="copy-tooltip" role="status" aria-live="polite" class="pointer-events-none fixed left-1/2 top-24 z-300 -translate-x-1/2 rounded-md border border-accent-400/40 bg-surface-900/95 px-4 py-2 text-sm font-medium text-surface-50 opacity-0 shadow-lg transition-opacity duration-200 light:border-accent-600/40 light:bg-white/95 light:text-surface-950">
	Copied!
</div>

<script>
(function () {
	function showTooltip(msg: string) {
		const tooltip = document.getElementById('copy-tooltip');
		if (!tooltip) return;
		tooltip.textContent = msg;
		tooltip.style.opacity = '1';
		setTimeout(() => { tooltip.style.opacity = '0'; }, 1500);
	}

	// Reveal the native share button on devices that actually support it.
	function revealNativeShare() {
		if (typeof navigator !== 'undefined' && typeof navigator.share === 'function') {
			document.querySelectorAll<HTMLButtonElement>('.share-native-btn').forEach((el) => {
				el.hidden = false;
			});
		}
	}
	revealNativeShare();
	document.addEventListener('astro:page-load', revealNativeShare);

	document.addEventListener('click', async function (e) {
		const target = e.target as Element;

		// Native share (Web Share API)
		const nativeBtn = target.closest<HTMLButtonElement>('.share-native-btn');
		if (nativeBtn) {
			const title = nativeBtn.dataset.shareTitle || document.title;
			const url = nativeBtn.dataset.shareUrl || location.href;
			try {
				await (navigator as any).share({ title, url });
			} catch (_) {
				// User cancelled or share unsupported — quietly ignore
			}
			return;
		}

		// Copy link
		const copyBtn = target.closest<HTMLElement>('[data-copy-url]');
		if (!copyBtn) return;
		const url = copyBtn.dataset.copyUrl;
		if (!url) return;
		try {
			await navigator.clipboard.writeText(url);
			showTooltip('Copied!');
		} catch (_) {
			try {
				const ta = document.createElement('textarea');
				ta.value = url;
				ta.style.position = 'fixed';
				ta.style.opacity = '0';
				document.body.appendChild(ta);
				ta.select();
				document.execCommand('copy');
				document.body.removeChild(ta);
				showTooltip('Copied!');
			} catch (__) {}
		}
	});
})();
</script>
