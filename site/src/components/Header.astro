---
const currentPath = Astro.url.pathname;

const navLinks = [
	{ href: '/', label: 'Entries' },
	{ href: '/team', label: 'Team' },
];
---

<header class="sticky top-0 z-50 border-b border-surface-800 bg-surface-950/80 backdrop-blur-lg light:border-surface-200 light:bg-surface-50/80">
	<nav class="mx-auto flex max-w-4xl items-center justify-between px-6 py-4">
		<a href="/" class="group flex items-center gap-3 text-lg font-bold no-underline">
			<span class="text-2xl" aria-hidden="true">🌙</span>
			<span class="text-surface-100 light:text-surface-900">
				Shipping <span class="text-surface-500 light:text-surface-700">in the</span> Dark
			</span>
		</a>

		<div class="flex items-center gap-6">
			{navLinks.map(({ href, label }) => (
				<a
					href={href}
					class:list={[
						'text-sm font-medium no-underline transition-colors',
						currentPath === href || (href !== '/' && currentPath.startsWith(href))
							? 'text-accent-400 light:text-accent-700'
							: 'text-surface-400 hover:text-surface-100 light:text-surface-600 light:hover:text-surface-900',
					]}
				>
					{label}
				</a>
			))}
			<button
				id="theme-toggle"
				type="button"
				class="rounded-full p-2 text-surface-400 transition-colors hover:bg-surface-800 hover:text-surface-100 light:text-surface-600 light:hover:bg-surface-200 light:hover:text-surface-900 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent-600"
				aria-label="Toggle theme"
			>
				<svg class="dark-icon hidden h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
				</svg>
				<svg class="light-icon hidden h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
				</svg>
			</button>
		</div>
	</nav>
</header>

<script is:inline>
	const toggle = document.getElementById('theme-toggle');
	const html = document.documentElement;
	const darkIcon = toggle.querySelector('.dark-icon');
	const lightIcon = toggle.querySelector('.light-icon');

	function updateIcons() {
		const isLight = html.classList.contains('light');
		darkIcon.classList.toggle('hidden', isLight);
		lightIcon.classList.toggle('hidden', !isLight);
	}

	updateIcons();

	toggle.addEventListener('click', () => {
		const isLight = html.classList.toggle('light');
		localStorage.setItem('theme', isLight ? 'light' : 'dark');
		updateIcons();
	});
</script>
