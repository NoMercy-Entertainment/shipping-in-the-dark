---
import { getCollection, render } from 'astro:content';
import fs from 'node:fs';
import path from 'node:path';
import { fileURLToPath } from 'node:url';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ReportAudioPlayer from '../../components/ReportAudioPlayer.astro';
import AudioSync from '../../components/AudioSync.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import ArticleSource from '../../components/ArticleSource.astro';

// Parse a VTT file and return the highest end-timestamp (in seconds).
// Used to pre-compute each part's audio duration so the player can
// show a report-wide total instead of just the current part.
function vttDuration(vttRelPath: string): number {
	try {
		const siteRoot = path.dirname(fileURLToPath(new URL('../..', import.meta.url)));
		const full = path.join(siteRoot, 'public', vttRelPath.replace(/^\//, ''));
		const text = fs.readFileSync(full, 'utf-8');
		let max = 0;
		const re = /\d+:\d+:\d+\.\d+\s*-->\s*(\d+):(\d+):(\d+)\.(\d+)/g;
		let m: RegExpExecArray | null;
		while ((m = re.exec(text)) !== null) {
			const secs = Number(m[1]) * 3600 + Number(m[2]) * 60 + Number(m[3]) + Number(`0.${m[4]}`);
			if (secs > max) max = secs;
		}
		return max;
	} catch {
		return 0;
	}
}

const allParts = await getCollection('reports', (p) => p.id.startsWith('the-effortless-encoder/'));
const parts = allParts.sort((a, b) => a.data.part - b.data.part);

const slugify = (s: string): string =>
	s.toLowerCase()
		.replace(/[^a-z0-9]+/g, '-')
		.replace(/^-+|-+$/g, '');

const rendered = await Promise.all(
	parts.map(async (part) => {
		const { Content, headings } = await render(part);
		const slug = part.id.replace('the-effortless-encoder/', '').replace(/\.md$/, '');
		// Derive a hash slug from the human title so the URL tracks the
		// section name (e.g. #why-we-built-our-own-encoder) instead of
		// the internal filename (#part-00-overview).
		const hashSlug = slugify(part.data.title);
		return { part, slug, hashSlug, Content, headings };
	}),
);

const AUDIO_BASE = 'https://github.com/NoMercy-Entertainment/shipping-in-the-dark/releases/download/audio-v1';
const VTT_BASE = '/audio/reports/the-effortless-encoder';

const tracks = rendered.map(({ part, slug }) => {
	const vttFemaleBrief = `${VTT_BASE}/${slug}.female.brief.vtt`;
	const vttFemaleElaborate = `${VTT_BASE}/${slug}.female.elaborate.vtt`;
	const vttMaleBrief = `${VTT_BASE}/${slug}.male.brief.vtt`;
	const vttMaleElaborate = `${VTT_BASE}/${slug}.male.elaborate.vtt`;
	// Precompute per-track duration per voice/variant from the VTT so the
	// player can show a report-wide total instead of the current part's
	// duration. We store all four because voice + variant swaps change
	// the total; the player picks the right one at runtime.
	return {
		slug,
		title: part.data.title,
		part: part.data.part,
		audio: {
			female: {
				brief: `${AUDIO_BASE}/the-effortless-encoder--${slug}.female.brief.mp3`,
				elaborate: `${AUDIO_BASE}/the-effortless-encoder--${slug}.female.elaborate.mp3`,
			},
			male: {
				brief: `${AUDIO_BASE}/the-effortless-encoder--${slug}.male.brief.mp3`,
				elaborate: `${AUDIO_BASE}/the-effortless-encoder--${slug}.male.elaborate.mp3`,
			},
		},
		vtt: {
			female: { brief: vttFemaleBrief, elaborate: vttFemaleElaborate },
			male: { brief: vttMaleBrief, elaborate: vttMaleElaborate },
		},
		duration: {
			female: {
				brief: vttDuration(vttFemaleBrief),
				elaborate: vttDuration(vttFemaleElaborate),
			},
			male: {
				brief: vttDuration(vttMaleBrief),
				elaborate: vttDuration(vttMaleElaborate),
			},
		},
	};
});

const title = 'NoMercy MediaServer — The Effortless Encoder';
const description = 'A deep report on the orchestration behind NoMercy MediaServer\'s video and audio encoding — architecture, codecs, safety net, hardware, content analysis, subtitles, DRM, live transcode, disc ripping, distributed encoding, and roadmap.';
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const reportSourcePath = 'reports/the-effortless-encoder/';
---

<BaseLayout title={title} description={description} ogType="article">
	<Header />

	<div class="report-shell mx-auto px-4 py-12 sm:px-6">
		<aside class="report-sidebar" aria-label="Report contents">
			<div class="report-sidebar-inner">
				<button
					id="report-toc-toggle"
					class="report-toc-toggle"
					type="button"
					aria-expanded="false"
					aria-controls="report-toc-list"
				>
					<span>Contents</span>
					<svg class="chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" width="14" height="14">
						<polyline points="6 9 12 15 18 9"></polyline>
					</svg>
				</button>
				<nav class="report-toc" aria-label="Report parts">
					<h2 class="report-toc-heading">Contents</h2>
					<ol id="report-toc-list" class="report-toc-list">
						{rendered.map(({ part, slug, hashSlug }) => (
							<li>
								<a
									href={`#${hashSlug}`}
									class="report-toc-link"
									data-part-slug={slug}
								>
									<span class="report-toc-marker">
										{part.data.part === 0 ? 'Intro' : String(part.data.part).padStart(2, '0')}
									</span>
									<span class="report-toc-title">{part.data.title}</span>
								</a>
							</li>
						))}
					</ol>
				</nav>
			</div>
		</aside>

		<main class="report-main">
			<article>
				<header class="prose mb-8">
					<div class="mb-4 inline-flex items-center rounded-full bg-accent-400/10 px-3 py-1 text-sm font-medium text-accent-400 light:bg-accent-600/10 light:text-accent-700">
						Report · {parts.length} parts
					</div>
					<h1 class="mb-4 text-3xl font-bold leading-tight tracking-tight text-surface-50 sm:text-4xl light:text-surface-950">
						{title}
					</h1>
					<p class="text-surface-400 light:text-surface-700">
						{description}
					</p>
				</header>

				{rendered.map(({ part, slug, hashSlug, Content }) => (
					<section
						id={hashSlug}
						class="report-part"
						data-part-slug={slug}
						data-part-hash-slug={hashSlug}
						data-part-index={part.data.part}
					>
						<div class="prose part-body">
							<Content />
						</div>
					</section>
				))}

				<div class="mt-12 flex flex-col items-center gap-4 border-t border-surface-800 pt-8 light:border-surface-200">
					<ShareButtons title={title} url={canonicalUrl} prominent={true} />
					<ArticleSource path={reportSourcePath} label="View report source on GitHub" />
				</div>
			</article>
		</main>
	</div>

	<Footer />

	<AudioSync />
	<ReportAudioPlayer tracks={tracks} title={title} />
</BaseLayout>

<style is:global>
	/* ------------------------------------------------------------------ */
	/* Shell — sidebar + main column                                       */
	/* ------------------------------------------------------------------ */
	.report-shell {
		max-width: 84rem;       /* 1344px — room for a wider sidebar */
		display: grid;
		gap: 3rem;
	}

	@media (min-width: 1024px) {
		.report-shell {
			grid-template-columns: 22rem minmax(0, 1fr);
			gap: 4rem;
		}
	}

	@media (min-width: 1280px) {
		.report-shell {
			grid-template-columns: 24rem minmax(0, 1fr);
		}
	}

	.report-main {
		max-width: 48rem;       /* prose readable width */
		min-width: 0;
	}

	/* ------------------------------------------------------------------ */
	/* Sidebar                                                              */
	/* ------------------------------------------------------------------ */
	.report-sidebar {
		order: -1;               /* keep sidebar above main on mobile */
	}

	.report-sidebar-inner {
		background-color: var(--color-surface-900);
		border: 1px solid var(--color-surface-800);
		border-radius: 10px;
		padding: 1rem 1.25rem;
	}

	html.light .report-sidebar-inner {
		background-color: var(--color-surface-100);
		border-color: var(--color-surface-200);
	}

	@media (min-width: 1024px) {
		.report-sidebar {
			order: 0;
		}
		.report-sidebar-inner {
			position: sticky;
			top: 88px;              /* below the site header */
			max-height: calc(100vh - 120px);
			overflow-y: auto;
		}
	}

	/* Collapse toggle — visible on mobile only */
	.report-toc-toggle {
		display: inline-flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.5rem;
		width: 100%;
		font-size: 0.75rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--color-surface-500);
		background: transparent;
		border: none;
		cursor: pointer;
		padding: 0.25rem 0;
		outline: none;
	}
	html.light .report-toc-toggle { color: var(--color-surface-600); }
	.report-toc-toggle:focus-visible {
		outline: 2px solid var(--color-accent-400);
		outline-offset: 2px;
		border-radius: 4px;
	}
	.report-toc-toggle .chevron {
		transition: transform 0.2s ease;
	}
	.report-toc-toggle[aria-expanded="true"] .chevron {
		transform: rotate(180deg);
	}
	.report-toc-heading {
		display: none;
	}

	@media (min-width: 1024px) {
		.report-toc-toggle { display: none; }
		.report-toc-heading {
			display: block;
			font-size: 0.75rem;
			font-weight: 600;
			text-transform: uppercase;
			letter-spacing: 0.08em;
			color: var(--color-surface-500);
			margin: 0 0 0.75rem 0;
		}
		html.light .report-toc-heading { color: var(--color-surface-600); }
	}

	/* TOC list — collapsed by default on mobile */
	.report-toc-list {
		list-style: none;
		padding: 0;
		margin: 0.5rem 0 0 0;
		display: none;
	}
	.report-toc[data-open="true"] .report-toc-list {
		display: block;
	}
	@media (min-width: 1024px) {
		.report-toc-list { display: block; margin-top: 0; }
	}

	.report-toc-list li + li { margin-top: 0.1rem; }

	.report-toc-link {
		display: flex;
		align-items: baseline;
		gap: 0.75rem;
		padding: 0.35rem 0.5rem;
		border-radius: 6px;
		color: var(--color-surface-300);
		text-decoration: none;
		font-size: 0.875rem;
		line-height: 1.4;
		transition: color 0.15s ease, background-color 0.15s ease;
	}
	html.light .report-toc-link { color: var(--color-surface-700); }

	.report-toc-link:hover {
		color: var(--color-accent-400);
		background-color: var(--color-surface-800);
	}
	html.light .report-toc-link:hover {
		color: var(--color-accent-700);
		background-color: var(--color-surface-200);
	}

	.report-toc-link.active {
		color: var(--color-accent-400);
		background-color: var(--color-surface-800);
	}
	html.light .report-toc-link.active {
		color: var(--color-accent-700);
		background-color: var(--color-surface-200);
	}

	.report-toc-marker {
		flex-shrink: 0;
		font-family: var(--font-mono);
		font-size: 0.6875rem;
		color: var(--color-surface-500);
		min-width: 2.25rem;
	}
	html.light .report-toc-marker { color: var(--color-surface-500); }

	.report-toc-link.active .report-toc-marker {
		color: var(--color-accent-400);
	}
	html.light .report-toc-link.active .report-toc-marker {
		color: var(--color-accent-700);
	}

	.report-toc-title {
		min-width: 0;
	}

	/* ------------------------------------------------------------------ */
	/* Parts                                                                */
	/* ------------------------------------------------------------------ */
	.report-part {
		/* Anchor offset is handled globally via html { scroll-padding-top:
		   88px } — do NOT add scroll-margin-top here or the two stack and
		   the section lands ~170px below the header with blank space. */
		padding-top: 2rem;
		margin-top: 2rem;
		border-top: 1px solid var(--color-surface-800);
	}
	html.light .report-part {
		border-top-color: var(--color-surface-200);
	}
	.report-part:first-of-type {
		border-top: none;
		padding-top: 0;
		margin-top: 0;
	}

	/*
	  Each report part's markdown opens with `# Part Title`. That is the
	  same text the sidebar lists, so it MUST render on the page — hiding
	  it leaves #part-{slug} anchors landing on a section with no heading.
	  Give the per-part h1 a visually distinct size so the top-level page
	  h1 still reads as the primary title.
	*/
	.part-body h1 {
		font-size: 1.875rem;
		line-height: 1.25;
		letter-spacing: -0.01em;
		margin-top: 0;
		margin-bottom: 0.5em;
	}
</style>

<script is:inline>
(function () {
	// Mobile collapse toggle for the contents sidebar.
	function wireToggle() {
		var btn = document.getElementById('report-toc-toggle');
		var nav = document.querySelector('.report-toc');
		if (!btn || !nav) return;
		// Expanded by default on desktop, collapsed on mobile.
		var isDesktop = window.matchMedia('(min-width: 1024px)').matches;
		nav.setAttribute('data-open', isDesktop ? 'true' : 'false');
		btn.setAttribute('aria-expanded', isDesktop ? 'true' : 'false');
		btn.onclick = function () {
			var open = nav.getAttribute('data-open') === 'true';
			nav.setAttribute('data-open', String(!open));
			btn.setAttribute('aria-expanded', String(!open));
		};
	}
	wireToggle();
	document.addEventListener('astro:page-load', wireToggle);
})();
</script>
