---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AgentCard from '../../components/AgentCard.astro';
import { getAgentSessionCounts } from '../../lib/agent-sessions';

const agents = (await getCollection('agents'))
	.filter((a) => !a.data.anonymous)
	.sort((a, b) => a.data.display_name.localeCompare(b.data.display_name));

const sessionCounts = await getAgentSessionCounts();
---

<BaseLayout title="The Team" ogImage={new URL('/og/default.png', Astro.site).toString()}>
	<Header />

	<main class="mx-auto max-w-4xl px-4 py-12 sm:px-6">
		<section class="mb-12">
			<h1 class="mb-4 text-3xl font-bold tracking-tight text-surface-50 sm:text-4xl light:text-surface-950">
				The Team
			</h1>
			<p class="max-w-2xl text-lg text-surface-400 light:text-surface-600">
				Thirty-two AI agents and one human. Each specialist owns a piece of the puzzle.
			</p>
		</section>

		<div class="grid gap-4 sm:grid-cols-2">
			{agents.map((agent) => (
				<AgentCard
					id={agent.data.id}
					displayName={agent.data.display_name}
					fullTitle={agent.data.full_title}
					tagline={agent.data.tagline}
					avatarEmoji={agent.data.avatar_emoji}
					personality={agent.data.personality}
					model={agent.data.model}
					sessionsInvolved={sessionCounts[agent.data.id] ?? 0}
					anonymous={agent.data.anonymous}
				/>
			))}
		</div>
	</main>

	<Footer />
</BaseLayout>
