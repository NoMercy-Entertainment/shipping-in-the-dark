---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
	const agents = await getCollection('agents');
	return agents.map((agent) => ({
		params: { slug: agent.data.id },
		props: { agent },
	}));
}

const { agent } = Astro.props;
const { Content } = await render(agent);

const ogImage = new URL(`/og/team/${agent.data.id}.png`, Astro.site).toString();

const modelLabels: Record<string, string> = {
	opus: 'Claude Opus',
	sonnet: 'Claude Sonnet',
	haiku: 'Claude Haiku',
	human: 'Human',
};

const modelColors: Record<string, string> = {
	opus: 'bg-purple-500/15 text-purple-400',
	sonnet: 'bg-sky-500/15 text-sky-400',
	haiku: 'bg-emerald-500/15 text-emerald-400',
	human: 'bg-amber-500/15 text-amber-400',
};
---

<BaseLayout title={agent.data.display_name} description={agent.data.tagline} ogImage={ogImage}>
	<Header />

	<main class="mx-auto max-w-4xl px-6 py-12">
		<header class="mb-12 text-center">
			<span class="mb-4 inline-block text-6xl" aria-hidden="true">{agent.data.avatar_emoji}</span>
			<h1 class="mb-2 text-3xl font-bold text-surface-50 light:text-surface-950">{agent.data.display_name}</h1>
			<p class="mb-4 text-surface-400 light:text-surface-600">{agent.data.full_title}</p>
			<p class="mb-6 text-lg italic text-surface-400 light:text-surface-600">"{agent.data.tagline}"</p>

			<div class="flex flex-wrap justify-center gap-2">
				<span class={`inline-flex items-center rounded-full px-3 py-1 text-sm font-medium ${modelColors[agent.data.model] || modelColors.sonnet}`}>
					{modelLabels[agent.data.model] || agent.data.model}
				</span>
				<span class="inline-flex items-center rounded-full bg-surface-800 px-3 py-1 text-sm text-surface-400 light:bg-surface-200 light:text-surface-600">
					{agent.data.pronouns}
				</span>
				{agent.data.personality.map((trait: string) => (
					<span class="inline-flex items-center rounded-full bg-surface-800 px-3 py-1 text-sm text-surface-400 light:bg-surface-200 light:text-surface-600">
						{trait.replace(/-/g, ' ')}
					</span>
				))}
			</div>
		</header>

		<div class="prose">
			<Content />
		</div>
	</main>

	<Footer />
</BaseLayout>
