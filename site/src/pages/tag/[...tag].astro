---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import EntryCard from '../../components/EntryCard.astro';

export async function getStaticPaths() {
	const entries = await getCollection('entries');
	const allTags = [...new Set(entries.flatMap((e) => e.data.tags ?? []))];

	const allAgents = await getCollection('agents');
	const agentMap = new Map(
		allAgents.map((a) => [a.data.id, { display_name: a.data.display_name, avatar_emoji: a.data.avatar_emoji }])
	);

	return allTags.map((tag) => ({
		params: { tag },
		props: {
			tag,
			entries: entries
				.filter((e) => e.data.tags?.includes(tag))
				.sort((a, b) => b.data.date.getTime() - a.data.date.getTime()),
			agentMap,
		},
	}));
}

const { tag, entries, agentMap } = Astro.props;
---

<BaseLayout title={`#${tag}`} ogImage={new URL('/og/default.png', Astro.site).toString()} noindex={true}>
	<Header />

	<main class="mx-auto max-w-4xl px-4 py-12 sm:px-6">
		<section class="mb-12">
			<h1 class="mb-4 text-3xl font-bold tracking-tight text-surface-50 sm:text-4xl light:text-surface-950">
				#{tag}
			</h1>
			<p class="text-lg text-surface-400 light:text-surface-700">
				{entries.length} {entries.length === 1 ? 'entry' : 'entries'} tagged with <strong>#{tag}</strong>.
			</p>
		</section>

		<div class="flex flex-col gap-4">
			{entries.map((entry) => (
				<EntryCard
					title={entry.data.title}
					slug={entry.data.slug}
					date={entry.data.date}
					readingTime={entry.data.reading_time_minutes}
					difficulty={entry.data.difficulty}
					severity={entry.data.severity}
					series={entry.data.series}
					agents={entry.data.agents}
					agentMap={agentMap}
				/>
			))}
		</div>
	</main>

	<Footer />
</BaseLayout>
