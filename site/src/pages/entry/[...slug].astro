---
import { getCollection, render } from 'astro:content';
import EntryLayout from '../../layouts/EntryLayout.astro';

// Audio URL map — keyed by entry slug.
// URLs come from GitHub Releases once audio publishing is set up.
// For now, a placeholder drives the player UI for testing.
const audioUrls: Record<string, string> = {
	'2026-03-16-001-how-the-cto-locked-the-boss-out': '/audio/test-output.mp3',
};

export async function getStaticPaths() {
	const entries = await getCollection('entries');
	return entries.map((entry) => ({
		params: { slug: entry.data.slug },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

const ogImage = new URL(`/og/${entry.data.slug}.png`, Astro.site).toString();

const descriptionParts: string[] = [entry.data.title];
if (entry.data.series) {
	descriptionParts.push(`${entry.data.series.name}, Part ${entry.data.series.part}`);
}
if (entry.data.type) {
	descriptionParts.push(entry.data.type);
}
const description = descriptionParts.join(' — ');

const audioUrl = audioUrls[entry.data.slug];
---

<EntryLayout
	title={entry.data.title}
	date={entry.data.date}
	description={description}
	ogImage={ogImage}
	readingTime={entry.data.reading_time_minutes}
	difficulty={entry.data.difficulty}
	severity={entry.data.severity}
	sessionStart={entry.data.session_start}
	sessionEnd={entry.data.session_end}
	durationMinutes={entry.data.duration_minutes}
	series={entry.data.series}
	author={entry.data.author}
	headings={headings}
	tags={entry.data.tags ?? []}
	audioUrl={audioUrl}
>
	<Content />
</EntryLayout>
