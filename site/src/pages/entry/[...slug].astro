---
import { getCollection, render } from 'astro:content';
import EntryLayout from '../../layouts/EntryLayout.astro';

export async function getStaticPaths() {
	const entries = await getCollection('entries');
	return entries.map((entry) => ({
		params: { slug: entry.data.slug },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

const ogImage = new URL(`/og/${entry.data.slug}.png`, Astro.site).toString();

let description: string;
if (entry.data.excerpt) {
	description = entry.data.excerpt;
} else {
	const descriptionParts: string[] = [entry.data.title];
	if (entry.data.series) {
		descriptionParts.push(`${entry.data.series.name}, Part ${entry.data.series.part}`);
	}
	if (entry.data.type) {
		descriptionParts.push(entry.data.type);
	}
	description = descriptionParts.join(' — ');
}
---

<EntryLayout
	title={entry.data.title}
	date={entry.data.date}
	description={description}
	ogImage={ogImage}
	readingTime={entry.data.reading_time_minutes}
	difficulty={entry.data.difficulty}
	severity={entry.data.severity}
	sessionStart={entry.data.session_start}
	sessionEnd={entry.data.session_end}
	durationMinutes={entry.data.duration_minutes}
	series={entry.data.series}
	author={entry.data.author}
	headings={headings}
	tags={entry.data.tags ?? []}
	audioUrl={entry.data.audio_url}
	vttUrl={entry.data.vtt_url}
>
	<Content />
</EntryLayout>
