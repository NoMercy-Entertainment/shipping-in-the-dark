---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AgentTooltip from '../components/AgentTooltip.astro';
import TableOfContents from '../components/TableOfContents.astro';
import TagList from '../components/TagList.astro';
import AudioPlayer from '../components/AudioPlayer.astro';
import AudioSync from '../components/AudioSync.astro';

interface Props {
	title: string;
	date: Date;
	description?: string;
	ogImage?: string;
	readingTime?: number;
	difficulty?: string;
	severity?: string;
	sessionStart?: string;
	sessionEnd?: string;
	durationMinutes?: number;
	series?: { name: string; part: number };
	author?: string;
	headings?: { depth: number; slug: string; text: string }[];
	tags?: string[];
	audioUrl?: string;
	vttUrl?: string;
}

const {
	title,
	date,
	description,
	ogImage,
	readingTime,
	difficulty,
	severity,
	sessionStart,
	sessionEnd,
	durationMinutes,
	series,
	author,
	headings = [],
	tags = [],
	audioUrl,
	vttUrl,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();

const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'BlogPosting',
	headline: title,
	datePublished: date.toISOString(),
	author: {
		'@type': 'Organization',
		name: 'NoMercy Entertainment',
	},
	publisher: {
		'@type': 'Organization',
		name: 'NoMercy Entertainment',
		url: 'https://nomercy.tv',
	},
	url: canonicalUrl,
	...(description ? { description } : {}),
	...(ogImage ? { image: ogImage } : {}),
};

const formattedDate = date.toLocaleDateString('en-US', {
	weekday: 'long',
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});

const severityColors: Record<string, string> = {
	critical: 'text-red-400 light:text-red-700',
	major: 'text-amber-400 light:text-amber-700',
	minor: 'text-sky-400 light:text-sky-700',
};

const difficultyLabels: Record<string, string> = {
	beginner: 'Beginner-friendly',
	intermediate: 'Intermediate',
	advanced: 'Advanced',
};
---

<BaseLayout title={title} description={description} ogImage={ogImage}>
	<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />

	<div id="reading-progress" class="fixed top-0 left-0 h-1 bg-accent-400 z-[100] transition-none" style="width: 0%"></div>

	<Header />

	<main class="mx-auto max-w-4xl px-4 py-12 sm:px-6">
		<article>
			<header class="prose mb-12">
				{series && (
					<a href={`/series/${series.name.toLowerCase()}`} class="mb-4 inline-flex items-center rounded-full bg-accent-400/10 px-3 py-1 text-sm font-medium text-accent-400 no-underline transition-colors hover:bg-accent-400/20 light:bg-accent-600/10 light:text-accent-700">
						{series.name} · Part {series.part}
					</a>
				)}

				<h1 class="mb-4 text-3xl font-bold leading-tight tracking-tight text-surface-50 sm:text-4xl light:text-surface-950">
					{title}
				</h1>

				<div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-surface-500 light:text-surface-700">
					<time datetime={date.toISOString()}>{formattedDate}</time>
					{readingTime && <span>{readingTime} min read</span>}
					{difficulty && <span>{difficultyLabels[difficulty] || difficulty}</span>}
					{severity && severity !== 'none' && (
						<span class={severityColors[severity] || ''}>
							{severity.charAt(0).toUpperCase() + severity.slice(1)}
						</span>
					)}
					{durationMinutes && (
						<span>Session: {Math.floor(durationMinutes / 60)}h {durationMinutes % 60}m</span>
					)}
					{author && <span>by {author}</span>}
				</div>
			</header>

			<TableOfContents headings={headings} />

			<div class="prose">
				<slot />
			</div>

			<TagList tags={tags} />
		</article>
		<AgentTooltip />
	</main>

	<Footer />

	<AudioSync vttUrl={vttUrl} />
	<AudioPlayer audioUrl={audioUrl} title={title} />
</BaseLayout>

<script is:inline>
(function() {
	const bar = document.getElementById('reading-progress');
	if (!bar) return;

	function updateProgress() {
		const scrollTop = window.scrollY;
		const docHeight = document.documentElement.scrollHeight - window.innerHeight;
		const progress = docHeight > 0 ? Math.min((scrollTop / docHeight) * 100, 100) : 0;
		bar.style.width = progress + '%';
	}

	window.addEventListener('scroll', updateProgress, { passive: true });
	updateProgress();
})();
</script>
